<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Airbnb | <%= home.name %>
    </title>
    <link rel="stylesheet" href="/output.css">
</head>

<body class="bg-slate-950 text-slate-200 min-h-screen flex flex-col font-sans selection:bg-[#ff385c]/30">

    <header
        class="sticky top-0 z-50 w-full flex flex-col md:flex-row justify-between items-center px-6 py-4 md:px-12 bg-slate-950/80 backdrop-blur-xl border-b border-slate-800/60 shadow-sm shadow-slate-900/20">
        <a href="/"
            class="flex items-center gap-2 text-[#ff385c] font-bold text-2xl tracking-tight mb-4 md:mb-0 transition-transform duration-300">
            <svg class="w-8 h-8 fill-current" viewBox="0 0 32 32" xmlns="http://www.w3.org/2000/svg">
                <path
                    d="M16 1.4c-8.1 0-14.6 6.5-14.6 14.6 0 8.1 6.5 14.6 14.6 14.6 8.1 0 14.6-6.5 14.6-14.6 0-8.1-6.5-14.6-14.6-14.6zm0 27.2c-7 0-12.6-5.6-12.6-12.6 0-7 5.6-12.6 12.6-12.6 7 0 12.6 5.6 12.6 12.6 0 7-5.6 12.6-12.6 12.6zm3.6-17.1c-1-1.1-2.2-1.7-3.6-1.7-1.4 0-2.6.6-3.6 1.7-1.1 1.2-1.8 3-1.8 5.2s.7 4 1.8 5.2c1 1.1 2.2 1.7 3.6 1.7 1.4 0 2.6-.6 3.6-1.7 1.1-1.2 1.8-3 1.8-5.2s-.7-4-1.8-5.2zm-1.5 8.9c-.6.6-1.3.9-2.1.9-.8 0-1.5-.3-2.1-.9-.6-.7-.9-1.9-.9-3.7 0-1.8.3-3 .9-3.7.6-.6 1.3-.9 2.1-.9.8 0 1.5.3 2.1.9.6.7.9 1.9.9 3.7 0 1.8-.3 3-.9 3.7z" />
            </svg>
            Airbnb
        </a>

        <%-include('../partials/userNavPartial')%>
    </header>

    <main class="flex-grow max-w-7xl mx-auto w-full p-6 lg:p-12">
        <a href="/user/home-list"
            class="inline-flex items-center text-slate-400 hover:text-[#ff385c] mb-6 font-semibold transition-colors duration-200">
            <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18">
                </path>
            </svg>
            Back to listings
        </a>

        <div
            class="relative w-full h-[50vh] min-h-[400px] max-h-[600px] rounded-[2rem] overflow-hidden mb-12 shadow-2xl border border-slate-800 group">
            <img src="<%=home.photo%>" alt="<%=home.name%>"
                class="w-full h-full object-cover transition-transform duration-1000 ease-in-out group-hover:scale-105">
            <div class="absolute top-6 left-6 z-10">
                <span
                    class="bg-slate-900/80 backdrop-blur-md text-white text-xs font-bold px-4 py-2 rounded-full uppercase tracking-widest border border-slate-700/50 shadow-lg flex items-center gap-2">
                    <svg class="w-4 h-4 text-[#36e630]" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd"
                            d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
                            clip-rule="evenodd"></path>
                    </svg>
                    Verified Property
                </span>
            </div>
            <div
                class="absolute inset-0 bg-gradient-to-t from-slate-950/80 via-transparent to-transparent pointer-events-none">
            </div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-12 relative">

            <div class="lg:col-span-2 flex flex-col gap-10">

                <div>
                    <h1 class="text-4xl md:text-5xl font-extrabold text-white mb-4 tracking-tight leading-tight">
                        <%=home.name%>
                    </h1>
                    <div class="flex items-center text-slate-300 text-lg font-medium">
                        <svg class="w-6 h-6 mr-2 text-[#ff385c]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z">
                            </path>
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
                        </svg>
                        <%=home.location%>
                    </div>
                </div>

                <hr class="border-slate-800/80">

                <div class="flex items-center gap-5">
                    <div
                        class="w-16 h-16 rounded-full bg-gradient-to-tr from-[#ff385c] to-purple-600 p-[2px] shadow-lg">
                        <img src="<%= owner.profilePicture || '/images/default-pfp.webp' %>" alt="Profile Picture"
                            class="w-full h-full rounded-full object-cover object-center border-4 border-slate-800 group-hover:border-[#ff385c]/50 transition-colors duration-300 shadow-inner">
                    </div>
                    <div>
                        <a href="/user/host-profile/<%= owner.id %>">
                            <h3 class="text-white font-bold text-xl hover:text-[#f75d79] transition-all duration-75">
                                <%= owner.firstName %>
                                    <%= owner.lastName %>
                            </h3>
                        </a>
                        <% if (yearsHosting>= 5) { %>
                            <span
                                class="inline-block bg-[#ff385c] text-white text-xs font-bold px-2 py-1 rounded-full uppercase tracking-widest mb-1">Superhost</span>
                            <p class="text-slate-400">
                                <%= yearsHosting %> years hosting
                            </p>
                            <% } else if(yearsHosting>= 1) { %>
                                <p class="text-slate-400">
                                    <%= yearsHosting %> years hosting
                                </p>
                                <% } else { %>
                                    <p class="text-slate-400">
                                        New host
                                    </p>
                                    <% } %>
                    </div>
                </div>

                <hr class="border-slate-800/80">

                <div>
                    <h2 class="text-2xl font-bold text-white tracking-tight">About this space</h2>
                    <div class="text-slate-300 text-lg leading-relaxed font-light">
                        <p class="whitespace-pre-line">
                            <%= home.description %>
                        </p>
                    </div>
                </div>

                <hr class="border-slate-800/80">

                <div>
                    <h2 class="text-2xl font-bold text-white mb-8 tracking-tight">What this place offers</h2>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 text-slate-300 text-lg font-light">
                        <div class="flex items-center gap-4"><svg class="w-7 h-7 text-slate-500" fill="none"
                                stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                                    d="M8.111 16.404a5.5 5.5 0 017.778 0M12 20h.01m-7.08-7.071c3.904-3.905 10.236-3.905 14.141 0M1.394 9.393c5.857-5.857 15.355-5.857 21.213 0">
                                </path>
                            </svg> Fast Wi-Fi</div>
                        <div class="flex items-center gap-4"><svg class="w-7 h-7 text-slate-500" fill="none"
                                stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                                    d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z">
                                </path>
                            </svg> Dedicated workspace</div>
                        <div class="flex items-center gap-4"><svg class="w-7 h-7 text-slate-500" fill="none"
                                stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                                    d="M13 10V3L4 14h7v7l9-11h-7z"></path>
                            </svg> Free parking on premises</div>
                        <div class="flex items-center gap-4"><svg class="w-7 h-7 text-slate-500" fill="none"
                                stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                                    d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9">
                                </path>
                            </svg> Beautiful view</div>
                    </div>
                </div>
            </div>

            <div class="relative">
                <div
                    class="sticky top-28 flex flex-col gap-6 max-h-[calc(100vh-8rem)] overflow-y-auto pb-4 [&::-webkit-scrollbar]:hidden [-ms-overflow-style:none] [scrollbar-width:none]">

                    <div
                        class="bg-slate-900/90 backdrop-blur-xl border border-slate-700/60 rounded-3xl p-8 shadow-2xl flex flex-col gap-6 shrink-0">

                        <div class="flex items-end gap-1 mb-2">
                            <span class="text-white font-black text-4xl tracking-tight">$<%=home.price%></span>
                            <span class="text-slate-400 font-medium mb-1 text-lg">/ night</span>
                        </div>

                        <div class="border border-slate-700 rounded-xl overflow-hidden bg-slate-950/50">
                            <div class="flex border-b border-slate-700">
                                <div
                                    class="w-1/2 p-3 border-r border-slate-700 cursor-pointer hover:bg-slate-900 transition">
                                    <div class="text-[10px] font-bold uppercase text-slate-400 tracking-wider">Check-in
                                    </div>
                                    <div class="text-slate-200 text-sm mt-1">Add date</div>
                                </div>
                                <div class="w-1/2 p-3 cursor-pointer hover:bg-slate-900 transition">
                                    <div class="text-[10px] font-bold uppercase text-slate-400 tracking-wider">Checkout
                                    </div>
                                    <div class="text-slate-200 text-sm mt-1">Add date</div>
                                </div>
                            </div>
                            <div class="p-3 cursor-pointer hover:bg-slate-900 transition">
                                <div class="text-[10px] font-bold uppercase text-slate-400 tracking-wider">Guests</div>
                                <div class="text-slate-200 text-sm mt-1">1 guest</div>
                            </div>
                        </div>

                        <button
                            class="inline-flex items-center justify-center gap-2 px-8 py-4 text-center bg-[#ff385c] text-white rounded-xl font-bold text-lg hover:bg-[#e03150] transition-all duration-300 shadow-lg shadow-[#ff385c]/20 transform active:scale-95 shrink-0">
                            Reserve Now
                        </button>

                        <div class="text-center text-slate-400 text-sm font-medium">
                            You won't be charged yet
                        </div>

                        <hr class="border-slate-800/80 mt-2">

                        <div class="flex flex-col gap-4 text-slate-300">
                            <div class="flex justify-between items-center">
                                <span class="cursor-pointer hover:text-white transition">$<%=home.price%> x 5
                                        nights</span>
                                <span>$<%= Number(home.price) * 5 %></span>
                            </div>
                            <div class="flex justify-between items-center">
                                <span class="cursor-pointer hover:text-white transition">Cleaning fee</span>
                                <span>$85</span>
                            </div>
                            <div class="flex justify-between items-center">
                                <span class="cursor-pointer hover:text-white transition">Airbnb service fee</span>
                                <span>$120</span>
                            </div>
                        </div>

                        <hr class="border-slate-800/80">

                        <div class="flex justify-between items-center text-white font-extrabold text-xl pt-2">
                            <span>Total before taxes</span>
                            <span>$<%= (Number(home.price) * 5) + 205 %></span>
                        </div>
                    </div>

                    <div class="w-full shrink-0">
                        <form action="/user/rules/<%= home._id%>" method="POST" class="w-full m-0">

                            <button type="submit"
                                class="w-full group flex items-center justify-between px-5 py-4 bg-slate-900/50 backdrop-blur-md border border-slate-700/50 rounded-2xl hover:bg-slate-800/80 hover:border-[#ff385c]/40 transition-all duration-300 shadow-sm hover:shadow-[0_5px_20px_-5px_rgba(255,56,92,0.2)] active:scale-[0.98]">

                                <div class="flex items-center gap-4">
                                    <div
                                        class="p-2.5 bg-slate-950 border border-slate-800 rounded-xl text-slate-400 group-hover:text-[#ff385c] group-hover:border-[#ff385c]/30 transition-all duration-300 shadow-inner">
                                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                                d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z">
                                            </path>
                                        </svg>
                                    </div>

                                    <div class="flex flex-col text-left">
                                        <span class="text-sm font-extrabold text-white tracking-wide mb-0.5">House Rules
                                            & Guide</span>
                                        <span
                                            class="text-[10px] font-bold text-slate-500 uppercase tracking-widest flex items-center gap-1.5">
                                            Download PDF
                                            <span class="w-1 h-1 rounded-full bg-slate-600"></span>
                                            2.4 MB
                                        </span>
                                    </div>
                                </div>

                                <svg class="w-5 h-5 text-slate-600 group-hover:text-white transition-all duration-300 group-hover:translate-x-1"
                                    fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                        d="M9 5l7 7-7 7">
                                    </path>
                                </svg>
                            </button>
                        </form>
                    </div>

                </div>
            </div>

        </div>
    </main>
</body>

</html>