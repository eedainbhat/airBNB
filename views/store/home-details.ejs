<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Airbnb | Home Details</title>
    <link rel="stylesheet" href="/output.css">
</head>

<body class="bg-slate-950 text-slate-200 min-h-screen flex flex-col font-sans selection:bg-[#ff385c]/30">

    <header
        class="sticky top-0 z-50 w-full flex flex-col md:flex-row justify-between items-center px-6 py-4 md:px-12 bg-slate-950/80 backdrop-blur-xl border-b border-slate-800/60 shadow-sm shadow-slate-900/20">
        <a href="/user"
            class="flex items-center gap-2 text-[#ff385c] font-bold text-2xl tracking-tight mb-4 md:mb-0 hover:scale-105 transition-transform duration-300">
            <svg class="w-8 h-8 fill-current" viewBox="0 0 32 32" xmlns="http://www.w3.org/2000/svg">
                <path
                    d="M16 1.4c-8.1 0-14.6 6.5-14.6 14.6 0 8.1 6.5 14.6 14.6 14.6 8.1 0 14.6-6.5 14.6-14.6 0-8.1-6.5-14.6-14.6-14.6zm0 27.2c-7 0-12.6-5.6-12.6-12.6 0-7 5.6-12.6 12.6-12.6 7 0 12.6 5.6 12.6 12.6 0 7-5.6 12.6-12.6 12.6zm3.6-17.1c-1-1.1-2.2-1.7-3.6-1.7-1.4 0-2.6.6-3.6 1.7-1.1 1.2-1.8 3-1.8 5.2s.7 4 1.8 5.2c1 1.1 2.2 1.7 3.6 1.7 1.4 0 2.6-.6 3.6-1.7 1.1-1.2 1.8-3 1.8-5.2s-.7-4-1.8-5.2zm-1.5 8.9c-.6.6-1.3.9-2.1.9-.8 0-1.5-.3-2.1-.9-.6-.7-.9-1.9-.9-3.7 0-1.8.3-3 .9-3.7.6-.6 1.3-.9 2.1-.9.8 0 1.5.3 2.1.9.6.7.9 1.9.9 3.7 0 1.8-.3 3-.9 3.7z" />
            </svg>
            Airbnb
        </a>

        <ul class="flex flex-wrap justify-center items-center gap-6 md:gap-10 text-sm font-semibold tracking-wide">
            <li><a href="/user"
                    class="text-slate-400 border-b-2 border-transparent hover:text-white hover:border-slate-600 pb-1 transition-all duration-300">Home</a>
            </li>
            <li><a href="/user/home-list"
                    class="active text-[#ff385c] border-b-2 border-[#ff385c] pb-1 transition-all duration-300">Home-list</a>
            </li>
            <li><a href="/user/favorites"
                    class="text-slate-400 border-b-2 border-transparent hover:text-white hover:border-slate-600 pb-1 transition-all duration-300">Favorites</a>
            </li>
            <li><a href="/user/reserved"
                    class="text-slate-400 border-b-2 border-transparent hover:text-white hover:border-slate-600 pb-1 transition-all duration-300">Reserved</a>
            </li>
            <li><a href="/user/bookings"
                    class="text-slate-400 border-b-2 border-transparent hover:text-white hover:border-slate-600 pb-1 transition-all duration-300">Bookings</a>
            </li>
            <li><a href="/"
                    class="text-green-400 border-b-2 border-transparent hover:text-white hover:border-slate-600 pb-1 transition-all duration-300">Logout</a>
            </li>
        </ul>
    </header>

    <main class="flex-grow max-w-5xl mx-auto w-full p-8 lg:p-12">
        <a href="/user/home-list"
            class="inline-flex items-center text-slate-400 hover:text-[#ff385c]  mb-8 font-semibold transition-colors duration-200">
            <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18">
                </path>
            </svg>
            Back to listings
        </a>

        <div class="bg-slate-900 border border-slate-800 rounded-3xl p-6 md:p-10 shadow-2xl relative overflow-hidden">
            <div class="absolute -top-24 -right-24 w-64 h-64 bg-[#ff385c]/10 rounded-full blur-[80px]"></div>

            <div
                class="w-full h-80 md:h-[450px] rounded-2xl overflow-hidden mb-10 relative z-10 border border-slate-800">
                <img src="<%=home.photo%>" alt="Property Photo"
                    class="w-full h-full object-cover hover:scale-105 transition-transform duration-700 ease-in-out">
                <div class="absolute top-4 left-4 right-4 flex justify-between items-center z-10">
                    <span
                        class="bg-slate-950/80 backdrop-blur-md text-white text-[10px] font-bold px-3 py-1 rounded-full uppercase tracking-widest border border-slate-700">
                        Verified
                    </span>
                </div>
            </div>

            <div class="flex flex-col lg:flex-row justify-between items-start gap-10 relative z-10">

                <div class="flex-grow">
                    <h1 class="text-4xl md:text-5xl font-extrabold text-white mb-4 tracking-tight">
                        <%=home.name%>
                    </h1>

                    <div class="flex items-center text-slate-400 text-lg font-medium mb-8">
                        <svg class="w-5 h-5 mr-2 text-slate-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z">
                            </path>
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
                        </svg>
                        <%=home.location%>
                    </div>

                    <hr class="border-slate-800 mb-8">

                    <div class="text-slate-400 text-lg leading-relaxed mb-8 max-w-2xl">
                        <div class="text-slate-400 text-lg leading-relaxed mb-8 max-w-2xl">
                            <p>A stunning <strong>
                                    <%= home.name %>
                                </strong>, located in <strong>
                                    <%= home.location %>
                                </strong>, is a very special property that offers the perfect getaway. Experience
                                absolute privacy and modern comforts in a beautiful setting, all just costing <strong>$<%= home.price %></strong> per night.</p>
                        </div>
                    </div>
                </div>

                <div
                    class="w-full lg:w-96 bg-slate-950/80 backdrop-blur-md rounded-3xl p-8 border border-slate-800 flex flex-col gap-8 shrink-0 shadow-xl">
                    <div class="flex items-end gap-2">
                        <span class="text-[#ff385c] font-black text-5xl tracking-tight">
                            <%=home.price%>
                        </span>
                        <span class="text-slate-400 text-sm font-semibold uppercase tracking-wider mb-2">/ night</span>
                    </div>

                    <button
                        class="flex justify-center w-full py-4 bg-white text-slate-950 hover:bg-[#ff385c] hover:text-white rounded-2xl font-bold transition-all transform active:scale-[0.98] shadow-lg cursor-pointer">
                        Reserve Now
                    </button>

                    <div class="text-center text-slate-500 text-sm font-medium">
                        You won't be charged yet
                    </div>
                </div>

            </div>
        </div>
    </main>
</body>

</html>