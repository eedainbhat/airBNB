<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Airbnb | Change Password</title>
    <link rel="stylesheet" href="/output.css">
</head>

<body
    class="w-full bg-[#020617] text-slate-200 min-h-screen flex flex-col font-sans overflow-x-hidden relative selection:bg-[#ff385c]/30">

    <div
        class="absolute top-[-10%] left-[-10%] w-[500px] h-[500px] bg-[#ff385c]/10 rounded-full mix-blend-screen filter blur-[150px] animate-[pulse_7s_ease-in-out_infinite] pointer-events-none z-0">
    </div>
    <div
        class="absolute bottom-[-10%] right-[-10%] w-[500px] h-[500px] bg-purple-500/10 rounded-full mix-blend-screen filter blur-[150px] animate-[pulse_9s_ease-in-out_infinite_reverse] pointer-events-none z-0">
    </div>

    <header class="relative z-20 w-full px-6 py-6 max-w-2xl mx-auto flex justify-between items-center">
        <a href="javascript:history.back()"
            class="inline-flex items-center gap-2 text-slate-400 hover:text-white transition-colors duration-300 group">
            <div
                class="p-2 bg-slate-900/50 border border-slate-800 rounded-xl group-hover:border-slate-600 group-hover:bg-slate-800 transition-all">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                        d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
                </svg>
            </div>
            <span class="font-semibold text-sm tracking-wide">Back</span>
        </a>
    </header>

    <main class="relative z-10 flex-grow w-full max-w-2xl mx-auto px-4 md:px-8 pb-20 flex flex-col justify-center">

        <div class="mb-8 text-center">
            <div
                class="w-16 h-16 mx-auto bg-slate-800/50 border border-slate-700 rounded-full flex items-center justify-center mb-6 shadow-inner">
                <svg class="w-8 h-8 text-slate-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                        d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z">
                    </path>
                </svg>
            </div>
            <h1 class="text-3xl md:text-4xl font-black text-white tracking-tight mb-2">Update Password</h1>
            <p class="text-slate-400 font-medium max-w-md mx-auto">Create a strong, unique password to keep your host
                account and personal data secure.</p>
        </div>

        <div class="bg-slate-900/40 backdrop-blur-xl border border-slate-800/60 rounded-[2rem] p-6 md:p-10 shadow-2xl">

            <form action="/change-password" method="POST" class="flex flex-col gap-6" id="passwordForm">

                <div class="flex flex-col gap-2">
                    <label for="currentPassword"
                        class="text-xs font-bold text-slate-400 uppercase tracking-widest pl-1">Current Password</label>
                    <div class="relative">
                        <input type="password"
                            value="<%= typeof oldInput !== 'undefined' ? oldInput.currentPassword : '' %>"
                            id="currentPassword" name="currentPassword"
                            class="w-full bg-slate-950/50 border border-slate-700/60 text-white rounded-xl px-4 py-3 pr-12 focus:outline-none focus:border-[#ff385c] focus:ring-1 focus:ring-[#ff385c] transition-all placeholder-slate-600"
                            placeholder="Enter your current password">
                        <button type="button" onclick="togglePassword('currentPassword', this)"
                            class="absolute right-4 top-1/2 -translate-y-1/2 text-slate-400 hover:text-slate-200 transition-colors focus:outline-none">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                    d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                    d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                            </svg>
                        </button>
                    </div>
                </div>

                <hr class="border-slate-800/60 my-2">

                <div class="flex flex-col gap-2">
                    <label for="newPassword" class="text-xs font-bold text-slate-400 uppercase tracking-widest pl-1">New
                        Password</label>
                    <div class="relative">
                        <input type="password"
                            value="<%= typeof oldInput !== 'undefined' ? oldInput.newPassword : '' %>" id="newPassword"
                            name="newPassword"
                            class="w-full bg-slate-950/50 border border-slate-700/60 text-white rounded-xl px-4 py-3 pr-12 focus:outline-none focus:border-[#ff385c] focus:ring-1 focus:ring-[#ff385c] transition-all placeholder-slate-600"
                            placeholder="At least 8 characters">
                        <button type="button" onclick="togglePassword('newPassword', this)"
                            class="absolute right-4 top-1/2 -translate-y-1/2 text-slate-400 hover:text-slate-200 transition-colors focus:outline-none">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                    d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                    d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                            </svg>
                        </button>
                    </div>
                </div>

                <div class="flex flex-col gap-2 relative">
                    <label for="confirmPassword"
                        class="text-xs font-bold text-slate-400 uppercase tracking-widest pl-1">Confirm New
                        Password</label>
                    <div class="relative">
                        <input type="password"
                            value="<%= typeof oldInput !== 'undefined' ? oldInput.confirmPassword : '' %>"
                            id="confirmPassword" name="confirmPassword"
                            class="w-full bg-slate-950/50 border border-slate-700/60 text-white rounded-xl px-4 py-3 pr-12 focus:outline-none focus:border-[#ff385c] focus:ring-1 focus:ring-[#ff385c] transition-all placeholder-slate-600"
                            placeholder="Type your new password again">
                        <button type="button" onclick="togglePassword('confirmPassword', this)"
                            class="absolute right-4 top-1/2 -translate-y-1/2 text-slate-400 hover:text-slate-200 transition-colors focus:outline-none">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                    d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                    d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                            </svg>
                        </button>
                    </div>
                </div>

                <%-include('../partials/errorsPartial')%>

                    <div>
                        <button type="submit"
                            class="w-full py-3.5 bg-[#ff385c] hover:bg-[#e03150] text-white font-semibold text-base rounded-xl transition-colors duration-200 active:scale-[0.98] shadow-lg shadow-[#ff385c]/20">
                            Update Password
                        </button>
                    </div>
            </form>

        </div>
    </main>
    <script>
        function togglePassword(inputId, button) {
            const input = document.getElementById(inputId);
            const svg = button.querySelector('svg');

            if (input.type === 'password') {
                // Unhide password
                input.type = 'text';
                // Switch to "Eye Closed" icon (slash)
                svg.innerHTML = `
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l3.59 3.59m0 0A9.953 9.953 0 0112 5c4.478 0 8.268 2.943 9.543 7a10.025 10.025 0 01-4.132 5.411m0 0L21 21" />
            `;
            } else {
                // Hide password
                input.type = 'password';
                // Switch back to "Eye Open" icon
                svg.innerHTML = `
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
            `;
            }
        }
    </script>
</body>

</html>