<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sector Empty | Portal</title>
    <link rel="stylesheet" href="/output.css">
    <style>
        /* Floating Animation */
        @keyframes float {
            0%, 100% { transform: translateY(0) scale(1); }
            50% { transform: translateY(-15px) scale(1.01); }
        }
        .animate-float { animation: float 6s ease-in-out infinite; }

        /* Rotating Radar Sweep */
        @keyframes radar-spin {
            from { transform: rotate(0deg); }
            to { transform: rotate(360deg); }
        }
        .radar-sweep {
            background: conic-gradient(from 0deg, transparent 70%, rgba(6, 182, 212, 0.1) 80%, rgba(6, 182, 212, 0.6) 100%);
            animation: radar-spin 4s linear infinite;
            border-radius: 50%;
        }

        /* Pulsing Target Rings */
        @keyframes ping-slow {
            0% { transform: scale(0.8); opacity: 0.8; }
            100% { transform: scale(2); opacity: 0; }
        }
        .ring-ping {
            animation: ping-slow 3s cubic-bezier(0, 0, 0.2, 1) infinite;
        }

        /* Button Light Sweep */
        @keyframes shimmer {
            100% { transform: translateX(200%); }
        }

        /* Ambient Noise Overlay */
        .bg-noise {
            background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.8' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)'/%3E%3C/svg%3E");
            opacity: 0.04;
        }

        /* Custom Scrollbar */
        ::-webkit-scrollbar { width: 8px; height: 8px; }
        ::-webkit-scrollbar-track { background: #020617; }
        ::-webkit-scrollbar-thumb { background: #06abd4; border-radius: 8px; }
        ::-webkit-scrollbar-thumb:hover { background: #8b5cf6; }
    </style>
</head>
<body class="bg-[#020617] text-slate-200 min-h-screen flex flex-col items-center justify-center font-sans overflow-hidden relative selection:bg-cyan-500/30">
    
    <div class="absolute inset-0 z-0 opacity-[0.03] pointer-events-none" 
         style="background-image: radial-gradient(circle at 2px 2px, white 1px, transparent 0); background-size: 40px 40px;">
    </div>
    <div class="absolute inset-0 z-50 bg-noise pointer-events-none mix-blend-overlay"></div>

    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] md:w-[800px] h-[600px] md:h-[800px] border border-cyan-900/20 rounded-full pointer-events-none flex items-center justify-center">
        <div class="absolute w-[300px] md:w-[400px] h-[300px] md:h-[400px] border border-cyan-900/30 rounded-full"></div>
        <div class="absolute w-full h-[1px] bg-cyan-900/20"></div>
        <div class="absolute h-full w-[1px] bg-cyan-900/20"></div>
        <div class="absolute inset-0 radar-sweep"></div>
        <div class="absolute w-4 h-4 bg-cyan-500 rounded-full shadow-[0_0_20px_5px_rgba(6,182,212,0.5)] ring-ping"></div>
    </div>

    <div class="absolute top-[20%] left-[20%] w-[400px] h-[400px] bg-cyan-600/10 rounded-full mix-blend-screen filter blur-[100px] animate-[pulse_5s_ease-in-out_infinite] pointer-events-none"></div>
    <div class="absolute bottom-[20%] right-[20%] w-[500px] h-[500px] bg-violet-600/10 rounded-full mix-blend-screen filter blur-[120px] animate-[pulse_7s_ease-in-out_infinite_reverse] pointer-events-none"></div>

    <div class="relative z-10 flex flex-col items-center justify-center w-full max-w-3xl px-6 py-12">
        
        <div class="relative w-full flex flex-col items-center text-center rounded-[2rem] bg-[#0f172a]/60 backdrop-blur-xl border border-cyan-900/30 p-10 md:p-16 shadow-[0_0_50px_-15px_rgba(6,182,212,0.15)] animate-float">
            
            <div class="relative inline-block mb-2">
                <h1 class="text-8xl md:text-[12rem] font-black text-transparent bg-clip-text bg-gradient-to-b from-white via-cyan-100 to-transparent tracking-tighter drop-shadow-[0_0_30px_rgba(6,182,212,0.3)] select-none opacity-90">
                    404
                </h1>
                <div class="absolute inset-0 bg-gradient-to-b from-transparent via-cyan-400/20 to-transparent w-full h-[10px] animate-[tracking_3s_linear_infinite]" style="animation-name: scan; animation-duration: 3s; animation-iteration-count: infinite; animation-timing-function: linear;"></div>
            </div>
            <style>@keyframes scan { 0% { top: 0; } 100% { top: 100%; opacity: 0; } }</style>
            
            <div class="space-y-4 max-w-2xl mx-auto z-20">
                <h2 class="text-2xl md:text-3xl font-bold text-white tracking-[0.2em] uppercase flex items-center justify-center gap-3">
                    <svg class="w-6 h-6 text-cyan-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
                    <span>Sector Empty</span>
                </h2>
                
                <p class="text-cyan-100/60 text-lg font-mono tracking-tight mb-8 max-w-md mx-auto leading-relaxed">
                    The portal coordinates point to an unmapped void. The page you are looking for does not exist in this dimension.
                </p>
                
                <% if (typeof url !== 'undefined') { %>
                <div class="inline-flex items-center gap-2 px-4 py-2 bg-black/40 rounded border border-cyan-900/50 text-sm font-mono mb-8">
                    <span class="text-cyan-500 font-bold">Query_></span> 
                    <span class="truncate max-w-[200px] md:max-w-[300px] text-cyan-200/80"><%= url %></span>
                </div>
                <% } %>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-4 w-full max-w-lg mt-4 z-20">
                
                <a href="/" class="group relative flex items-center justify-center gap-3 w-full px-8 py-4 bg-cyan-500 rounded-xl text-slate-950 font-bold transition-all duration-300 hover:bg-cyan-400 shadow-[0_0_20px_-5px_rgba(6,182,212,0.5)] hover:shadow-[0_0_30px_0px_rgba(6,182,212,0.7)] hover:scale-[1.02] active:scale-[0.98] overflow-hidden">
                    
                    <div class="absolute inset-0 w-full h-full bg-gradient-to-r from-transparent via-white/40 to-transparent -translate-x-full group-hover:animate-[shimmer_0.75s_infinite] skew-x-12 pointer-events-none"></div>
                    
                    <svg class="w-5 h-5 relative z-10 group-hover:-translate-x-1 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path>
                    </svg>
                    <span class="relative z-10 font-mono tracking-widest uppercase">Base Camp</span>
                </a>
                
                <button onclick="window.history.back()" class="group relative flex items-center justify-center gap-3 w-full px-8 py-4 bg-transparent border-2 border-cyan-900/50 hover:border-cyan-400 rounded-xl text-cyan-200 hover:text-cyan-50 font-bold transition-all duration-300 hover:bg-cyan-950/30 hover:scale-[1.02] active:scale-[0.98] hover:shadow-[0_0_15px_-3px_rgba(6,182,212,0.3)]">
                    
                    <svg class="w-5 h-5 text-cyan-600 group-hover:text-cyan-400 group-hover:-translate-x-1 transition-all duration-300 ease-in-out" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
                    </svg>
                    <span class="font-mono tracking-widest uppercase">Retreat</span>
                </button>
            </div>

        </div>
    </div>
</body>
</html>