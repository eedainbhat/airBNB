<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Airbnb | Portal</title>
    <link rel="stylesheet" href="/output.css">
</head>

<body
    class="bg-[#020617] text-slate-200 min-h-screen flex flex-col items-center justify-center font-sans overflow-hidden relative selection:bg-[#ff385c]/30">

    <div
        class="absolute top-0 left-1/4 w-[500px] h-[500px] bg-[#ff385c]/20 rounded-full mix-blend-screen filter blur-[128px] animate-[pulse_6s_ease-in-out_infinite] pointer-events-none">
    </div>
    <div
        class="absolute bottom-0 right-1/4 w-[500px] h-[500px] bg-emerald-500/15 rounded-full mix-blend-screen filter blur-[128px] animate-[pulse_8s_ease-in-out_infinite_reverse] pointer-events-none">
    </div>

    <% if(isLoggedIn) {%>
        <a href="/logout"
            class="absolute top-6 right-6 md:top-10 md:right-10 z-50 inline-flex items-center gap-2 px-5 py-2.5 bg-slate-900/40 backdrop-blur-md border border-slate-800/80 rounded-full text-slate-400 font-semibold text-sm tracking-wide transition-all duration-300 hover:bg-rose-500/10 hover:border-rose-500/40 hover:text-rose-400 hover:shadow-[0_0_25px_-5px_rgba(244,63,94,0.25)] active:scale-95 group">
            <span>Log Out</span>
            <svg class="w-4 h-4 transition-transform duration-300 group-hover:translate-x-1" fill="none"
                stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                    d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1">
                </path>
            </svg>
        </a>
        <%} else {%>
            <a href="/login"
                class="absolute top-6 right-6 md:top-10 md:right-10 z-50 inline-flex items-center gap-2 px-5 py-2.5 bg-slate-900/40 backdrop-blur-md border border-slate-800/80 rounded-full text-slate-400 font-semibold text-sm tracking-wide transition-all duration-300 hover:bg-emerald-500/10 hover:border-emerald-500/40 hover:text-emerald-400 hover:shadow-[0_0_25px_-5px_rgba(16,185,129,0.25)] active:scale-95 group">
                <span>Log In</span>
                <svg class="w-4 h-4 transition-transform duration-300 group-hover:translate-x-1" fill="none"
                    stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                        d="M15 12H3m12 0l-4-4m4 4l-4 4M15 3h4a2 2 0 012 2v14a2 2 0 01-2 2h-4">
                    </path>
                </svg>
            </a>
            <%}%>
                <div class="relative z-10 text-center mb-16 px-4">
                    <div
                        class="inline-flex items-center justify-center p-3 bg-slate-900/50 border border-slate-800 rounded-2xl mb-8 backdrop-blur-sm shadow-xl">
                        <svg class="w-9 h-9 text-white fill-current" viewBox="0 0 32 32"
                            xmlns="http://www.w3.org/2000/svg">
                            <path
                                d="M16 1.4c-8.1 0-14.6 6.5-14.6 14.6 0 8.1 6.5 14.6 14.6 14.6 8.1 0 14.6-6.5 14.6-14.6 0-8.1-6.5-14.6-14.6-14.6zm0 27.2c-7 0-12.6-5.6-12.6-12.6 0-7 5.6-12.6 12.6-12.6 7 0 12.6 5.6 12.6 12.6 0 7-5.6 12.6-12.6 12.6zm3.6-17.1c-1-1.1-2.2-1.7-3.6-1.7-1.4 0-2.6.6-3.6 1.7-1.1 1.2-1.8 3-1.8 5.2s.7 4 1.8 5.2c1 1.1 2.2 1.7 3.6 1.7 1.4 0 2.6-.6 3.6-1.7 1.1-1.2 1.8-3 1.8-5.2s-.7-4-1.8-5.2zm-1.5 8.9c-.6.6-1.3.9-2.1.9-.8 0-1.5-.3-2.1-.9-.6-.7-.9-1.9-.9-3.7 0-1.8.3-3 .9-3.7.6-.6 1.3-.9 2.1-.9.8 0 1.5.3 2.1.9.6.7.9 1.9.9 3.7 0 1.8-.3 3-.9 3.7z" />
                        </svg>
                        <div
                            class="flex items-center gap-2 text-[#ff385c] font-bold text-3xl ml-2 tracking-tight transition-transform duration-300">
                            Airbnb</div>
                    </div>
                    <h1 class="text-5xl md:text-7xl font-black mb-4 text-white tracking-tight drop-shadow-2xl">
                        Choose Your <span
                            class="text-transparent bg-clip-text bg-gradient-to-r from-[#ff3838] via-rose-400 to-emerald-400">Path</span>
                    </h1>
                    <p class="text-slate-400 text-lg md:text-xl font-medium tracking-wide">Select your portal
                        destination to
                        initialize the application.</p>
                </div>

                <div
                    class="relative z-10 flex flex-col md:flex-row gap-8 md:gap-12 w-full max-w-5xl px-8 perspective-1000">

                    <a href="/user"
                        class="group relative w-full md:w-1/2 flex flex-col h-[350px] rounded-[2.5rem] bg-slate-900/60 backdrop-blur-2xl border border-slate-700/50 p-10 transition-all duration-500 ease-out hover:scale-[1.05] hover:-translate-y-4 hover:-rotate-2 hover:border-[#ff385c]/50 hover:shadow-[0_20px_80px_-15px_rgba(255,56,92,0.4)] overflow-hidden cursor-pointer">

                        <div
                            class="absolute inset-0 bg-gradient-to-br from-[#ff385c]/20 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-700">
                        </div>

                        <div class="relative z-10 flex flex-col h-full justify-between">
                            <div
                                class="w-20 h-20 bg-slate-950 border border-slate-800 rounded-[1.5rem] flex items-center justify-center text-slate-400 group-hover:text-[#ff385c] group-hover:scale-110 transition-all duration-500 shadow-inner group-hover:shadow-[#ff385c]/30">
                                <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                        d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
                                </svg>
                            </div>
                            <div>
                                <h2
                                    class="text-4xl font-extrabold text-white mb-3 group-hover:text-[#ff385c] transition-colors duration-300 tracking-tight">
                                    Traveler</h2>
                                <p
                                    class="text-slate-400 font-medium flex items-center gap-3 group-hover:text-slate-200 transition-colors text-lg">
                                    Enter User Portal
                                    <svg class="w-6 h-6 opacity-0 -translate-x-4 group-hover:opacity-100 group-hover:translate-x-0 transition-all duration-300 text-[#ff385c]"
                                        fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3"
                                            d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
                                    </svg>
                                </p>
                            </div>
                        </div>
                    </a>

                    <a href="/host"
                        class="group relative w-full md:w-1/2 flex flex-col h-[350px] rounded-[2.5rem] bg-slate-900/60 backdrop-blur-2xl border border-slate-700/50 p-10 transition-all duration-500 ease-out hover:scale-[1.05] hover:-translate-y-4 hover:rotate-2 hover:border-emerald-500/50 hover:shadow-[0_20px_80px_-15px_rgba(16,185,129,0.4)] overflow-hidden cursor-pointer">

                        <div
                            class="absolute inset-0 bg-gradient-to-bl from-emerald-500/20 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-700">
                        </div>

                        <div class="relative z-10 flex flex-col h-full justify-between">
                            <div
                                class="w-20 h-20 bg-slate-950 border border-slate-800 rounded-[1.5rem] flex items-center justify-center text-slate-400 group-hover:text-emerald-400 group-hover:scale-110 transition-all duration-500 shadow-inner group-hover:shadow-emerald-500/30">
                                <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                        d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065zM15 12a3 3 0 11-6 0 3 3 0 016 0z">
                                    </path>
                                </svg>
                            </div>
                            <div>
                                <h2
                                    class="text-4xl font-extrabold text-white mb-3 group-hover:text-emerald-400 transition-colors duration-300 tracking-tight">
                                    Host / Admin</h2>
                                <p
                                    class="text-slate-400 font-medium flex items-center gap-3 group-hover:text-slate-200 transition-colors text-lg">
                                    Enter Admin Portal
                                    <svg class="w-6 h-6 opacity-0 -translate-x-4 group-hover:opacity-100 group-hover:translate-x-0 transition-all duration-300 text-emerald-400"
                                        fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3"
                                            d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
                                    </svg>
                                </p>
                            </div>
                        </div>
                    </a>

                </div>
</body>

</html>