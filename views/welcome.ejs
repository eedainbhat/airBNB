<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Airbnb | Welcome</title>
    <link rel="stylesheet" href="/output.css">
</head>
<body class="bg-[#020617] text-slate-200 min-h-screen flex flex-col font-sans overflow-hidden relative selection:bg-[#ff385c]/30">
    
    <div class="absolute top-[-10%] left-[-10%] w-[600px] h-[600px] bg-[#ff385c]/15 rounded-full mix-blend-screen filter blur-[150px] animate-[pulse_7s_ease-in-out_infinite] pointer-events-none"></div>
    <div class="absolute bottom-[-10%] right-[-10%] w-[600px] h-[600px] bg-emerald-500/10 rounded-full mix-blend-screen filter blur-[150px] animate-[pulse_9s_ease-in-out_infinite_reverse] pointer-events-none"></div>

    <header class="relative z-20 flex justify-between items-center w-full px-6 py-6 md:px-12 md:py-8 max-w-7xl mx-auto">
        <a href="/" class="flex items-center gap-2 text-[#ff385c] font-black text-2xl md:text-3xl tracking-tight transition-transform duration-300">
            <svg class="w-8 h-8 md:w-10 md:h-10 fill-current" viewBox="0 0 32 32" xmlns="http://www.w3.org/2000/svg">
                <path d="M16 1.4c-8.1 0-14.6 6.5-14.6 14.6 0 8.1 6.5 14.6 14.6 14.6 8.1 0 14.6-6.5 14.6-14.6 0-8.1-6.5-14.6-14.6-14.6zm0 27.2c-7 0-12.6-5.6-12.6-12.6 0-7 5.6-12.6 12.6-12.6 7 0 12.6 5.6 12.6 12.6 0 7-5.6 12.6-12.6 12.6zm3.6-17.1c-1-1.1-2.2-1.7-3.6-1.7-1.4 0-2.6.6-3.6 1.7-1.1 1.2-1.8 3-1.8 5.2s.7 4 1.8 5.2c1 1.1 2.2 1.7 3.6 1.7 1.4 0 2.6-.6 3.6-1.7 1.1-1.2 1.8-3 1.8-5.2s-.7-4-1.8-5.2zm-1.5 8.9c-.6.6-1.3.9-2.1.9-.8 0-1.5-.3-2.1-.9-.6-.7-.9-1.9-.9-3.7 0-1.8.3-3 .9-3.7.6-.6 1.3-.9 2.1-.9.8 0 1.5.3 2.1.9.6.7.9 1.9.9 3.7 0 1.8-.3 3-.9 3.7z" />
            </svg>
            Airbnb
        </a>

        <div class="flex items-center gap-4 md:gap-6">
            <a href="/login" class="text-sm md:text-base font-bold text-slate-300 hover:text-white transition-colors duration-200">
                Log in
            </a>
            <a href="/login" class="px-5 py-2.5 bg-slate-100 text-slate-900 rounded-full font-bold text-sm md:text-base hover:bg-white transition-all duration-300 shadow-[0_0_20px_-5px_rgba(255,255,255,0.3)]">
                Sign up
            </a>
        </div>
    </header>

    <main class="relative z-10 flex-grow flex flex-col items-center justify-center px-4 md:px-8 text-center pb-20">
        
        <div class="mb-6 inline-flex items-center gap-2 px-4 py-2 rounded-full bg-slate-900/50 border border-slate-700/50 backdrop-blur-md shadow-sm">
            <span class="w-2 h-2 rounded-full bg-emerald-400 animate-pulse"></span>
            <span class="text-xs font-bold uppercase tracking-widest text-slate-400">Discover your next stay</span>
        </div>

        <h1 class="max-w-4xl text-5xl md:text-7xl lg:text-8xl font-black text-white tracking-tighter leading-[1.1] mb-6 drop-shadow-2xl">
            Go anywhere, <br/>
            <span class="text-transparent bg-clip-text bg-gradient-to-r from-[#ff385c] via-rose-400 to-[#ff385c]">feel at home.</span>
        </h1>
        
        <p class="max-w-2xl text-lg md:text-xl text-slate-400 font-medium tracking-wide mb-10 md:mb-14">
            Join thousands of travelers and hosts. Log in to access your portal, book unforgettable getaways, or manage your premium listings.
        </p>

        <div class="flex flex-col sm:flex-row items-center gap-4 w-full max-w-md mx-auto">
            <a href="/login" class="w-full flex justify-center items-center gap-3 px-8 py-4 bg-[#ff385c] text-white rounded-2xl font-black text-lg hover:bg-[#e03150] transition-all duration-300 shadow-[0_10px_40px_-10px_rgba(255,56,92,0.6)] hover:shadow-[0_15px_50px_-10px_rgba(255,56,92,0.8)] hover:gap-5 active:scale-[0.98]">
                Log in to continue
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
                </svg>
            </a>
        </div>

    </main>

    <footer class="relative z-10 w-full py-6 text-center border-t border-slate-800/40 bg-slate-950/20 backdrop-blur-md">
        <p class="text-xs font-semibold text-slate-600 tracking-wider">
            &copy; <%= new Date().getFullYear() %> Airbnb Portal Clone. All rights reserved.
        </p>
    </footer>

</body>
</html>