<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SYSTEM_ERR // Portal</title>
    <link rel="stylesheet" href="/output.css">
    <style>
        /* Aggressive RGB Split & Tear for Text */
        @keyframes text-glitch-top {
            0% {
                clip-path: inset(20% 0 80% 0);
                transform: translate(-4px, 2px);
            }

            20% {
                clip-path: inset(60% 0 10% 0);
                transform: translate(4px, -2px);
            }

            40% {
                clip-path: inset(40% 0 50% 0);
                transform: translate(-4px, 1px);
            }

            60% {
                clip-path: inset(80% 0 5% 0);
                transform: translate(4px, -1px);
            }

            80% {
                clip-path: inset(10% 0 70% 0);
                transform: translate(-2px, 4px);
            }

            100% {
                clip-path: inset(30% 0 50% 0);
                transform: translate(2px, -4px);
            }
        }

        @keyframes text-glitch-bot {
            0% {
                clip-path: inset(10% 0 60% 0);
                transform: translate(4px, -2px);
            }

            20% {
                clip-path: inset(30% 0 20% 0);
                transform: translate(-4px, 2px);
            }

            40% {
                clip-path: inset(70% 0 10% 0);
                transform: translate(4px, -1px);
            }

            60% {
                clip-path: inset(20% 0 50% 0);
                transform: translate(-4px, 1px);
            }

            80% {
                clip-path: inset(50% 0 30% 0);
                transform: translate(2px, -4px);
            }

            100% {
                clip-path: inset(5% 0 80% 0);
                transform: translate(-2px, 4px);
            }
        }

        .glitch-heavy {
            position: relative;
        }

        .glitch-heavy::before,
        .glitch-heavy::after {
            content: attr(data-text);
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            opacity: 0.8;
            pointer-events: none;
        }

        .glitch-heavy::before {
            color: #0ff;
            z-index: -1;
            animation: text-glitch-top 0.3s cubic-bezier(0.25, 0.46, 0.45, 0.94) both infinite;
        }

        .glitch-heavy::after {
            color: #ff385c;
            z-index: -2;
            animation: text-glitch-bot 0.3s cubic-bezier(0.25, 0.46, 0.45, 0.94) both infinite reverse;
        }

        /* Screen Shake (Intermittent) */
        @keyframes screen-shake {

            0%,
            94%,
            100% {
                transform: translate(0, 0) scale(1);
                filter: hue-rotate(0deg);
            }

            95% {
                transform: translate(-5px, 5px) scale(1.01);
                filter: hue-rotate(90deg);
            }

            97% {
                transform: translate(5px, -5px) scale(1.01);
                filter: hue-rotate(-90deg);
            }

            99% {
                transform: translate(-5px, -5px) scale(1.01);
                filter: hue-rotate(45deg);
            }
        }

        .animate-shake {
            animation: screen-shake 5s infinite;
        }

        /* CRT Effects */
        @keyframes flicker {

            0%,
            19.9%,
            22%,
            62.9%,
            64%,
            64.9%,
            70%,
            100% {
                opacity: 0.99;
            }

            20%,
            21.9%,
            63%,
            63.9%,
            65%,
            69.9% {
                opacity: 0.8;
            }
        }

        .scanlines {
            background: linear-gradient(to bottom, rgba(255, 255, 255, 0), rgba(255, 255, 255, 0) 50%, rgba(0, 0, 0, 0.2) 50%, rgba(0, 0, 0, 0.2));
            background-size: 100% 4px;
        }

        .bg-noise {
            background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)'/%3E%3C/svg%3E");
            opacity: 0.06;
        }

        /* Tracking Line (VCR Error) */
        @keyframes tracking {
            0% {
                top: -10%;
                height: 2px;
                opacity: 0;
            }

            10% {
                opacity: 0.5;
            }

            50% {
                height: 10px;
                opacity: 0.1;
            }

            90% {
                opacity: 0.5;
            }

            100% {
                top: 110%;
                height: 2px;
                opacity: 0;
            }
        }

        .tracking-line {
            position: absolute;
            left: 0;
            width: 100%;
            background: rgba(255, 255, 255, 0.2);
            box-shadow: 0 0 10px rgba(255, 56, 92, 0.5);
            animation: tracking 4s linear infinite;
            pointer-events: none;
            z-index: 40;
        }

        ::-webkit-scrollbar {
            width: 8px;
            height: 8px;
        }

        ::-webkit-scrollbar-track {
            background: #020617;
        }

        ::-webkit-scrollbar-thumb {
            background: #475569;
        }

        ::-webkit-scrollbar-thumb:hover {
            background: #ff385c;
        }
    </style>
</head>

<body
    class="bg-[#020617] text-slate-200 min-h-screen flex flex-col items-center justify-center font-sans overflow-hidden relative selection:bg-[#ff385c]/50 animate-shake"
    style="animation-duration: 4s;">

    <div class="absolute inset-0 z-50 bg-noise pointer-events-none mix-blend-overlay"></div>
    <div class="absolute inset-0 z-50 scanlines pointer-events-none opacity-50"></div>
    <div class="tracking-line"></div>

    <div class="absolute inset-0 bg-red-900/10 mix-blend-multiply animate-pulse pointer-events-none"
        style="animation-duration: 2s;"></div>

    <div class="relative z-10 flex flex-col items-center justify-center w-full max-w-4xl px-6 py-12">

        <div
            class="relative w-full flex flex-col items-center text-center rounded-[1rem] md:rounded-[2rem] bg-[#0f172a]/80 backdrop-blur-md border-2 border-red-900/50 p-8 md:p-14 shadow-[0_0_50px_-15px_rgba(255,56,92,0.3)]">

            <div class="relative inline-block mb-4">
                <h1 class="text-8xl md:text-[10rem] font-black text-transparent bg-clip-text bg-gradient-to-b from-white via-red-500 to-[#ff385c] tracking-tighter drop-shadow-[0_0_20px_rgba(255,56,92,0.8)] z-10 relative glitch-heavy"
                    data-text="<%= typeof error !== 'undefined' && error.status ? error.status : 'ERR' %>">
                    <%= typeof error !=='undefined' && error.status ? error.status : 'ERR' %>
                </h1>
            </div>

            <div class="space-y-4 max-w-2xl mx-auto z-20">
                <h2
                    class="text-2xl md:text-3xl font-extrabold text-white tracking-[0.2em] uppercase flex items-center justify-center gap-3">
                    <span class="w-3 h-3 bg-[#ff385c] rounded-full animate-ping"></span>
                    <span class="scramble-text" data-original="SYSTEM FAILURE">SYSTEM FAILURE</span>
                </h2>

                <p class="scramble-text text-slate-400 text-lg md:text-xl font-mono tracking-tight mb-8"
                    data-original="<%= typeof message !== 'undefined' && message ? message : 'Node connection severed. An Unknown Error Occurred.' %>">
                    <%= typeof message !=='undefined' && message ? message
                        : 'Node connection severed. An Unknown Error Occurred.' %>
                </p>

                <% if (typeof url !=='undefined' ) { %>
                    <div
                        class="inline-flex items-center gap-2 px-4 py-2 bg-black/50 rounded border border-red-900/30 text-sm font-mono mb-8 w-full max-w-md">
                        <span class="text-[#ff385c] font-bold">TARGET_></span>
                        <span class="truncate text-red-200/80">
                            <%= url %>
                        </span>
                    </div>
                    <% } %>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-4 w-full max-w-lg mt-4 z-20">

                <a href="/"
                    class="group relative flex items-center justify-center gap-3 w-full px-8 py-4 bg-[#ff385c] rounded-xl text-white font-bold transition-all duration-300 hover:bg-red-600 shadow-[0_0_20px_-5px_rgba(255,56,92,0.6)] hover:shadow-[0_0_30px_0px_rgba(255,56,92,0.8)] hover:scale-[1.02] active:scale-[0.98] overflow-hidden">

                    <div
                        class="absolute inset-0 w-full h-full bg-gradient-to-r from-transparent via-white/20 to-transparent -translate-x-full group-hover:animate-[shimmer_0.75s_infinite] skew-x-12 pointer-events-none">
                    </div>

                    <svg class="w-5 h-5 relative z-10 group-hover:-translate-x-2 transition-transform duration-300"
                        fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5"
                            d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
                    </svg>
                    <span class="relative z-10 font-mono tracking-widest uppercase">Return To Portal</span>
                </a>

                <button onclick="window.location.reload()"
                    class="group relative flex items-center justify-center gap-3 w-full px-8 py-4 bg-transparent border-2 border-slate-700 hover:border-[#ff385c] rounded-xl text-slate-300 hover:text-white font-bold transition-all duration-300 hover:bg-red-950/20 hover:scale-[1.02] active:scale-[0.98] hover:shadow-[0_0_15px_-3px_rgba(255,56,92,0.3)]">

                    <svg class="w-5 h-5 text-slate-400 group-hover:text-[#ff385c] group-hover:rotate-180 transition-all duration-700 ease-in-out"
                        fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5"
                            d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15">
                        </path>
                    </svg>
                    <span class="font-mono tracking-widest uppercase">Retry</span>
                </button>
            </div>

            <% if (typeof error !=='undefined' && error.stack) { %>
                <div class="w-full mt-12 border-t border-slate-800 pt-8 z-20 text-left">
                    <button id="dev-toggle"
                        class="flex items-center justify-between w-full p-4 rounded bg-black/40 hover:bg-black/60 border border-slate-800 transition-colors">
                        <div class="flex items-center gap-3">
                            <div class="w-2 h-2 bg-red-500 rounded-full animate-pulse"></div>
                            <span class="font-mono font-semibold text-slate-400 uppercase tracking-widest text-sm">Dump
                                Stack Trace</span>
                        </div>
                        <svg id="chevron" class="w-5 h-5 text-slate-500 transition-transform duration-200" fill="none"
                            stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7">
                            </path>
                        </svg>
                    </button>

                    <div id="stack-container" class="hidden mt-4 relative">
                        <button id="copy-btn"
                            class="absolute top-4 right-4 p-2 bg-slate-800 hover:bg-slate-700 text-slate-300 rounded border border-slate-600 transition-colors z-10"
                            title="Copy to clipboard">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                    d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z">
                                </path>
                            </svg>
                        </button>
                        <pre
                            class="bg-black p-6 rounded border border-slate-800 text-xs font-mono text-red-500/80 overflow-x-auto max-h-[300px]"><code id="stack-trace"><%= error.stack %></code></pre>
                    </div>
                </div>
                <% } %>
        </div>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', () => {

            // --- Text Scrambler (Memory Corruption Effect) ---
            const scrambleElements = document.querySelectorAll('.scramble-text');
            const chars = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789!@#$%^&*()_+{}[]|;:<>?/';

            const scramble = (element) => {
                const originalText = element.getAttribute('data-original');
                let iterations = 0;
                const interval = setInterval(() => {
                    element.innerText = originalText.split('').map((letter, index) => {
                        if (index < iterations) return originalText[index];
                        return chars[Math.floor(Math.random() * chars.length)];
                    }).join('');

                    if (iterations >= originalText.length) clearInterval(interval);
                    iterations += 1 / 2; // Speed of unscrambling
                }, 40);
            };

            // Trigger scramble on load
            scrambleElements.forEach(el => scramble(el));

            // Periodically corrupt text to keep the glitch alive
            setInterval(() => {
                const randomEl = scrambleElements[Math.floor(Math.random() * scrambleElements.length)];
                const originalText = randomEl.getAttribute('data-original');
                const glitchChars = '!<>-_\\\\/[]{}—=+*^?#_0101';

                let corrupted = originalText.split('').map(char =>
                    Math.random() < 0.15 && char !== ' ' ? glitchChars[Math.floor(Math.random() * glitchChars.length)] : char
                ).join('');

                randomEl.innerText = corrupted;
                setTimeout(() => { randomEl.innerText = originalText; }, 100);
            }, 2500);

            // --- Developer Diagnostics ---
            const devToggle = document.getElementById('dev-toggle');
            const stackContainer = document.getElementById('stack-container');
            const chevron = document.getElementById('chevron');

            if (devToggle && stackContainer) {
                devToggle.addEventListener('click', () => {
                    if (stackContainer.classList.contains('hidden')) {
                        stackContainer.classList.remove('hidden');
                        stackContainer.classList.add('block');
                        chevron.style.transform = 'rotate(180deg)';
                    } else {
                        stackContainer.classList.add('hidden');
                        stackContainer.classList.remove('block');
                        chevron.style.transform = 'rotate(0deg)';
                    }
                });
            }

            const copyBtn = document.getElementById('copy-btn');
            const stackTrace = document.getElementById('stack-trace');

            if (copyBtn && stackTrace) {
                copyBtn.addEventListener('click', async () => {
                    try {
                        await navigator.clipboard.writeText(stackTrace.innerText);
                        const originalHTML = copyBtn.innerHTML;
                        copyBtn.innerHTML = `<span class="text-xs font-bold px-1 uppercase">Copied</span>`;
                        copyBtn.classList.replace('bg-slate-800', 'bg-emerald-600');
                        copyBtn.classList.replace('border-slate-600', 'border-emerald-500');

                        setTimeout(() => {
                            copyBtn.innerHTML = originalHTML;
                            copyBtn.classList.replace('bg-emerald-600', 'bg-slate-800');
                            copyBtn.classList.replace('border-emerald-500', 'border-slate-600');
                        }, 2000);
                    } catch (err) {
                        console.error('Copy failed', err);
                    }
                });
            }
        });
    </script>
</body>

</html>