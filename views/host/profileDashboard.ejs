<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Airbnb | Host Profile</title>
    <link rel="stylesheet" href="/output.css">
</head>

<body
    class="bg-[#020617] text-slate-200 min-h-screen flex flex-col font-sans overflow-x-hidden relative selection:bg-[#ff385c]/30">

    <div
        class="absolute top-[-10%] left-[-10%] w-[500px] h-[500px] bg-[#ff385c]/15 rounded-full mix-blend-screen filter blur-[150px] animate-[pulse_7s_ease-in-out_infinite] pointer-events-none">
    </div>
    <div
        class="absolute bottom-[-10%] right-[-10%] w-[500px] h-[500px] bg-emerald-500/10 rounded-full mix-blend-screen filter blur-[150px] animate-[pulse_9s_ease-in-out_infinite_reverse] pointer-events-none">
    </div>
    <header
        class="sticky top-0 z-50 w-full flex flex-col md:flex-row justify-between items-center px-6 py-4 md:px-12 bg-slate-950/80 backdrop-blur-xl border-b border-slate-800/60 shadow-sm shadow-slate-900/20">
        <div class="flex items-center gap-3 mb-4 md:mb-0">
            <a href="/"
                class="flex items-center gap-2 text-[#ff385c] font-bold text-2xl tracking-tight transition-transform duration-300">
                <svg class="w-8 h-8 fill-current" viewBox="0 0 32 32" xmlns="http://www.w3.org/2000/svg">
                    <path
                        d="M16 1.4c-8.1 0-14.6 6.5-14.6 14.6 0 8.1 6.5 14.6 14.6 14.6 8.1 0 14.6-6.5 14.6-14.6 0-8.1-6.5-14.6-14.6-14.6zm0 27.2c-7 0-12.6-5.6-12.6-12.6 0-7 5.6-12.6 12.6-12.6 7 0 12.6 5.6 12.6 12.6 0 7-5.6 12.6-12.6 12.6zm3.6-17.1c-1-1.1-2.2-1.7-3.6-1.7-1.4 0-2.6.6-3.6 1.7-1.1 1.2-1.8 3-1.8 5.2s.7 4 1.8 5.2c1 1.1 2.2 1.7 3.6 1.7 1.4 0 2.6-.6 3.6-1.7 1.1-1.2 1.8-3 1.8-5.2s-.7-4-1.8-5.2zm-1.5 8.9c-.6.6-1.3.9-2.1.9-.8 0-1.5-.3-2.1-.9-.6-.7-.9-1.9-.9-3.7 0-1.8.3-3 .9-3.7.6-.6 1.3-.9 2.1-.9.8 0 1.5.3 2.1.9.6.7.9 1.9.9 3.7 0 1.8-.3 3-.9 3.7z" />
                </svg>
                Airbnb
            </a>
            <span
                class="bg-[#ff385c]/10 text-[#ff385c] border border-[#ff385c]/20 text-[10px] font-bold uppercase tracking-wider py-1 px-2.5 rounded-md shadow-sm">
                Admin
            </span>
        </div>

        <%-include('../partials/hostNavPartial')%>
    </header>
    <section class="relative z-20 w-full px-6 py-6 max-w-5xl mx-auto flex justify-between items-center">

        <a href="javascript:history.back()"
            class="inline-flex items-center gap-2 text-slate-400 hover:text-white transition-colors duration-300 group">
            <div
                class="p-2 bg-slate-900/50 border border-slate-800 rounded-xl group-hover:border-slate-600 group-hover:bg-slate-800 transition-all">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                        d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
                </svg>
            </div>
            <span class="font-semibold text-sm tracking-wide">Back</span>
        </a>
        <a href="/host/edit-profile"
            class="inline-flex items-center justify-center gap-2 px-6 py-2.5 bg-slate-900/50 backdrop-blur-md border border-slate-700/60 text-slate-200 rounded-xl text-sm font-bold tracking-wide hover:bg-slate-800 hover:text-white hover:border-slate-500 hover:shadow-lg transition-all duration-300 active:scale-95">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                    d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z">
                </path>
            </svg>
            Edit Profile
        </a>
    </section>

    <main class="relative z-10 flex-grow w-full max-w-5xl mx-auto px-4 md:px-8 pb-20">

        <div
            class="bg-slate-900/40 backdrop-blur-xl border border-slate-800/60 rounded-[2.5rem] p-8 md:p-12 mb-12 shadow-2xl">
            <div class="flex flex-col md:flex-row items-center md:items-start gap-8 md:gap-12">
                <div class="relative shrink-0">
                    <div
                        class="absolute inset-0 bg-gradient-to-tr from-[#ff385c] to-purple-500 rounded-full blur-md opacity-50 animate-pulse">
                    </div>
                    <img src="<%= host.profilePicture || '/images/default-pfp.webp' %>"
                        alt="Host Profile Picture"
                        class="relative w-32 h-32 md:w-40 md:h-40 rounded-full object-cover border-4 border-slate-950 shadow-inner">
                </div>

                <div class="flex flex-col w-full text-center md:text-left">
                    <div class="flex flex-col md:flex-row md:items-center justify-between gap-6 mb-6">
                        <div>
                            <h1 class="text-3xl md:text-4xl font-black text-white tracking-tight mb-1">
                                <%= host.firstName %>
                                    <%= host.lastName %>
                            </h1>
                            <p class="text-sm font-semibold text-[#ff385c] tracking-wide">
                                <%= host.email %>
                            </p>
                        </div>
                    </div>

                    <div
                        class="flex flex-wrap justify-center md:justify-start gap-8 md:gap-12 mb-6 py-5 border-y border-slate-800/50">

                        <div class="flex flex-col items-center md:items-start gap-1">
                            <span class="text-2xl font-bold text-white leading-none">
                                <%= homes.length %>
                            </span>
                            <span
                                class="text-[11px] font-semibold text-slate-400 uppercase tracking-widest">Listings</span>
                        </div>

                        <div class="flex flex-col items-center md:items-start gap-1">
                            <span class="text-2xl font-bold text-white leading-none">4.9</span>
                            <span class="text-[11px] font-semibold text-slate-400 uppercase tracking-widest">Avg
                                Rating</span>
                        </div>

                        <% if (yearsHosting>= 1) { %>
                            <div class="flex flex-col items-center md:items-start gap-1">
                                <span class="text-2xl font-bold text-white leading-none">
                                    <%= yearsHosting %>
                                </span>
                                <span class="text-[11px] font-semibold text-slate-400 uppercase tracking-widest">
                                    <%= yearsHosting===1 ? 'Year' : 'Years' %> Hosting
                                </span>
                            </div>
                            <% } else { %>
                                <div class="flex flex-col justify-center h-full pt-3">
                                    <span
                                        class="inline-flex items-center px-3 py-1 rounded-full bg-[#ff385c]/10 text-[#ff385c] text-[11px] font-bold uppercase tracking-widest border border-[#ff385c]/20">
                                        New Host
                                    </span>
                                </div>
                                <% } %>

                    </div>

                    <% if(host.bio ) {%>
                        <div class="max-w-2xl">
                            <p class="text-slate-300 text-sm md:text-base leading-relaxed">
                                <%= host.bio %>
                            </p>
                        </div>
                        <% } else { %>
                            <a href="/host/edit-profile">
                                <span
                                    class="text-blue-500 hover:text-blue-600 transition-all duration-300 tracking-wide">
                                    Add a bio
                                </span>
                            </a>
                            <% } %>
                </div>
            </div>
        </div>

        <div class="flex items-center justify-center gap-4 mb-8">
            <div class="h-px bg-gradient-to-r from-transparent via-slate-700 to-transparent flex-grow"></div>
            <div class="flex items-center gap-2 text-slate-400">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                        d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z">
                    </path>
                </svg>
                <span class="text-xs font-bold uppercase tracking-widest">Published Homes</span>
            </div>
            <div class="h-px bg-gradient-to-r from-slate-700 via-slate-700 to-transparent flex-grow"></div>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-6">
            <% homes.forEach(home=> { %>
                <div
                    class="group relative aspect-square rounded-[2rem] overflow-hidden bg-slate-900 border border-slate-800 shadow-lg transform transition-all duration-500 hover:-translate-y-2 hover:shadow-[0_20px_40px_-15px_rgba(255,56,92,0.3)] hover:border-[#ff385c]/50">

                    <img src="<%= home.photo %>" alt="Cabin"
                        class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110">

                    <a href="/host/host-homelist" class="absolute inset-0 z-10"></a>
                    <div
                        class="absolute top-4 right-4 z-20 flex gap-2 opacity-0 -translate-y-2 group-hover:opacity-100 group-hover:translate-y-0 transition-all duration-300">
                        <a href="/host/edit-homes/<%= home._id %>"
                            class="p-2 bg-slate-900/80 hover:bg-slate-700 text-white rounded-xl backdrop-blur-sm border border-slate-700 transition-colors shadow-lg"
                            title="Edit Home">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                    d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z">
                                </path>
                            </svg>
                        </a>
                        <form action="/host/delete-home/<%= home._id %>" method="POST" class="inline m-0">
                            <input type="hidden" name="returnTo" value="/host/profile-dashboard">
                            <button type="submit"
                                class="p-2 bg-slate-900/80 hover:bg-[#ff385c] text-white rounded-xl backdrop-blur-sm border border-slate-700 hover:border-[#ff385c] transition-colors shadow-lg"
                                title="Delete Home">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                        d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16">
                                    </path>
                                </svg>
                            </button>
                        </form>
                    </div>

                    <div
                        class="absolute inset-0 bg-gradient-to-t from-slate-950 via-slate-900/40 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex flex-col justify-end p-6 pointer-events-none z-10">
                        <h3
                            class="text-xl font-black text-white tracking-tight mb-1 translate-y-4 group-hover:translate-y-0 transition-transform duration-300">
                            <%= home.name %>
                        </h3>
                        <div
                            class="flex items-center justify-between translate-y-4 group-hover:translate-y-0 transition-transform duration-300 delay-75">
                            <p class="text-sm font-medium text-slate-300 flex items-center gap-1">
                                <svg class="w-4 h-4 text-[#ff385c]" fill="none" stroke="currentColor"
                                    viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                        d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z">
                                    </path>
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                        d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
                                </svg>
                                <%= home.location %>
                            </p>
                            <span class="bg-[#ff385c] text-white text-xs font-bold px-3 py-1.5 rounded-lg shadow-md">
                                $<%= home.price %>/nt
                            </span>
                        </div>
                    </div>

                </div>
                <% }) %>

                    <a href="/host/add-home"
                        class="group relative aspect-square rounded-[2rem] bg-slate-900/30 border-2 border-dashed border-slate-700/60 flex flex-col items-center justify-center gap-5 cursor-pointer transform transition-all duration-500 hover:shadow-[0_20px_40px_-15px_rgba(255,56,92,0.3)] hover:border-[#ff385c]/60 hover:bg-slate-900/80">

                        <div
                            class="w-12 h-12 rounded-full bg-slate-800 border border-slate-700 flex items-center justify-center text-slate-400 group-hover:text-white transition-all duration-500 shadow-md">
                            <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                    d="M12 4v16m8-8H4"></path>
                            </svg>
                        </div>

                        <div class="flex flex-col items-center gap-1">
                            <h3
                                class="text-xl font-bold text-slate-400 group-hover:text-white transition-colors duration-300">
                                Add New Home</h3>
                            <p
                                class="text-xs font-semibold text-slate-500 uppercase tracking-widest group-hover:text-[#ff385c]/80 transition-colors duration-300">
                                Expand Portfolio</p>
                        </div>
                    </a>
        </div>
    </main>

</body>

</html>