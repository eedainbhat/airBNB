<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Airbnb Admin | Add Rules & Guide</title>
    <link rel="stylesheet" href="/output.css">
</head>

<body
    class="bg-[#020617] text-slate-200 min-h-screen flex flex-col font-sans overflow-x-hidden relative selection:bg-[#ff385c]/30">

    <div
        class="absolute top-[-10%] left-[-10%] w-[500px] h-[500px] bg-[#ff385c]/15 rounded-full mix-blend-screen filter blur-[150px] animate-[pulse_7s_ease-in-out_infinite] pointer-events-none">
    </div>
    <div
        class="absolute bottom-[-10%] right-[-10%] w-[500px] h-[500px] bg-emerald-500/10 rounded-full mix-blend-screen filter blur-[150px] animate-[pulse_9s_ease-in-out_infinite_reverse] pointer-events-none">
    </div>

    <header class="relative z-20 w-full px-6 py-6 max-w-4xl mx-auto flex justify-between items-center">
        <a href="javascript:history.back()"
            class="inline-flex items-center gap-2 text-slate-400 hover:text-white transition-colors duration-300 group">
            <div
                class="p-2 bg-slate-900/50 border border-slate-800 rounded-xl group-hover:border-slate-600 group-hover:bg-slate-800 transition-all shadow-sm">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                        d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
                </svg>
            </div>
            <span class="font-semibold text-sm tracking-wide">Back to Listing</span>
        </a>
        <div class="flex items-center gap-2 text-[#ff385c] font-bold text-xl tracking-tight">
            Airbnb <span
                class="bg-[#ff385c]/10 text-[#ff385c] border border-[#ff385c]/20 text-[10px] font-black uppercase tracking-wider py-1 px-2 rounded-md shadow-sm ml-1">Admin</span>
        </div>
    </header>

    <main class="relative z-10 flex-grow w-full max-w-4xl mx-auto px-4 md:px-8 pb-20 mt-4 md:mt-8">

        <div class="mb-10 text-center md:text-left">
            <h1 class="text-4xl md:text-5xl font-black text-white tracking-tight mb-3">House Manual & Rules</h1>
            <p class="text-slate-400 text-lg">Provide clear instructions and boundaries for your guests.</p>
        </div>

        <div
            class="bg-slate-900/60 backdrop-blur-2xl border border-slate-700/50 rounded-[2.5rem] shadow-[0_20px_80px_-15px_rgba(0,0,0,0.5)] overflow-hidden">

            <div class="bg-emerald-500/10 border-b border-emerald-500/20 p-6 md:px-10 flex gap-4 items-start">
                <div class="p-2 bg-emerald-500/20 text-emerald-400 rounded-xl shrink-0 mt-0.5">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                    </svg>
                </div>
                <div>
                    <h4 class="text-emerald-400 font-bold text-sm uppercase tracking-wider mb-1">Host Tip</h4>
                    <p class="text-slate-300 text-sm leading-relaxed">Consider including Wi-Fi details, check-out
                        procedures, quiet hours, and trash disposal instructions.</p>
                </div>
            </div>

            <form action="/host/add-rules/<%= home._id %>" method="POST" class="p-6 md:p-10 flex flex-col gap-8">
                <input type="hidden" name="homeId" value="<%= home._id %>">
                <div class="flex flex-col gap-3">
                    <label for="rules" class="text-sm font-bold text-slate-300 uppercase tracking-wider ml-1">
                        Rules & Instructions
                    </label>

                    <textarea id="rules" name="rules" rows="15" value
                        placeholder="Welcome to your home away from home!&#10;&#10;🏠 Wi-Fi Network: Guest_Net&#10;🔑 Password: relaxandunwind&#10;&#10;📌 Check-out is at 11:00 AM.&#10;📌 Please leave used towels in the bathtub.&#10;📌 Quiet hours begin at 10:00 PM."
                        class="w-full p-6 bg-slate-950/50 border border-slate-800 rounded-2xl text-slate-200 placeholder-slate-600/70 focus:outline-none focus:border-[#ff385c]/50 focus:ring-1 focus:ring-[#ff385c]/50 transition-all duration-300 shadow-inner resize-y text-base leading-relaxed"><%= home.rules ? home.rules : '' %></textarea>
                </div>

                <div
                    class="flex flex-col sm:flex-row items-center justify-between gap-6 pt-6 border-t border-slate-800/80">
                    <p class="text-xs text-slate-500 font-medium">
                        This information will be available to guests after booking.
                    </p>

                    <button type="submit"
                        class="w-full sm:w-auto inline-flex items-center justify-center gap-2 px-8 py-3.5 bg-[#ff385c] text-white rounded-xl font-bold tracking-wide hover:bg-[#e03150] transition-all duration-300 shadow-[0_0_20px_rgba(255,56,92,0.3)] hover:shadow-[0_0_30px_rgba(255,56,92,0.5)] active:scale-[0.98]">
                        Save Rules
                    </button>
                </div>

            </form>
        </div>
    </main>

</body>

</html>