<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Airbnb Admin | Edit Homes</title>
    <link rel="stylesheet" href="/output.css">
</head>
<body class="bg-slate-950 text-slate-200 min-h-screen font-sans flex flex-col selection:bg-[#ff385c]/30">
    
    <header class="sticky top-0 z-50 w-full flex flex-col md:flex-row justify-between items-center px-6 py-4 md:px-12 bg-slate-950/80 backdrop-blur-xl border-b border-slate-800/60 shadow-sm shadow-slate-900/20">
        <div class="flex items-center gap-3 mb-4 md:mb-0">
            <a href="/host/" class="flex items-center gap-2 text-[#ff385c] font-bold text-2xl tracking-tight transition-transform duration-300">
                <svg class="w-8 h-8 fill-current" viewBox="0 0 32 32" xmlns="http://www.w3.org/2000/svg">
                    <path d="M16 1.4c-8.1 0-14.6 6.5-14.6 14.6 0 8.1 6.5 14.6 14.6 14.6 8.1 0 14.6-6.5 14.6-14.6 0-8.1-6.5-14.6-14.6-14.6zm0 27.2c-7 0-12.6-5.6-12.6-12.6 0-7 5.6-12.6 12.6-12.6 7 0 12.6 5.6 12.6 12.6 0 7-5.6 12.6-12.6 12.6zm3.6-17.1c-1-1.1-2.2-1.7-3.6-1.7-1.4 0-2.6.6-3.6 1.7-1.1 1.2-1.8 3-1.8 5.2s.7 4 1.8 5.2c1 1.1 2.2 1.7 3.6 1.7 1.4 0 2.6-.6 3.6-1.7 1.1-1.2 1.8-3 1.8-5.2s-.7-4-1.8-5.2zm-1.5 8.9c-.6.6-1.3.9-2.1.9-.8 0-1.5-.3-2.1-.9-.6-.7-.9-1.9-.9-3.7 0-1.8.3-3 .9-3.7.6-.6 1.3-.9 2.1-.9.8 0 1.5.3 2.1.9.6.7.9 1.9.9 3.7 0 1.8-.3 3-.9 3.7z"/>
                </svg>
                Airbnb
            </a>
            <span class="bg-[#ff385c]/10 text-[#ff385c] border border-[#ff385c]/20 text-[10px] font-bold uppercase tracking-wider py-1 px-2.5 rounded-md shadow-sm">
                Admin
            </span>
        </div>

        <nav>
            <ul class="flex flex-wrap justify-center items-center gap-6 md:gap-10 text-sm font-semibold tracking-wide">
                <li><a href="/host/host-homelist" class="text-slate-400 border-b-2 border-transparent hover:text-white hover:border-slate-600 pb-1 transition-all duration-300">Home-list</a></li>
                <li><a href="/host/" class="text-slate-400 border-b-2 border-transparent hover:text-white hover:border-slate-600 pb-1 transition-all duration-300">Home</a></li>
                <li><a href="/" class="text-green-400 border-b-2 border-transparent hover:text-white hover:border-slate-600 pb-1 transition-all duration-300">Logout</a></li>
            </ul>
        </nav>
    </header>

    <main class="flex-grow max-w-7xl mx-auto w-full p-8 lg:p-12 relative flex flex-col items-center">
        
        <div class="mb-10 text-center w-full max-w-md">
            <h1 class="text-3xl font-extrabold text-white tracking-tight mb-2">Edit Listing</h1>
            <p class="text-slate-400">Modify property details, pricing, and availability here.</p>
        </div>

        <div class="w-full max-w-md bg-slate-900/80 backdrop-blur-xl border border-slate-800 p-10 rounded-[2rem] shadow-2xl relative z-10">
            <div class="w-14 h-14 bg-slate-950 border border-slate-800 rounded-full flex items-center justify-center mb-6 text-indigo-400 shadow-inner">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path></svg>
            </div>
            
            <form action='/host/edit-home' method='POST' class="space-y-5">
                <input type="hidden" name="homeId" value="<%=home._id %>">

                <div>
                    <label class="block text-xs font-bold text-slate-400 uppercase tracking-wider mb-2">Property Name</label>
                    <input class="w-full bg-slate-950 border border-slate-800 rounded-xl px-4 py-3.5 focus:outline-none focus:border-[#ff385c] focus:ring-1 focus:ring-[#ff385c] text-white transition-all placeholder:text-slate-600 shadow-inner" required type="text" name='name' value="<%=home.name %>">
                </div>
                
                <div class="flex gap-4">
                    <div class="w-1/2">
                        <label class="block text-xs font-bold text-slate-400 uppercase tracking-wider mb-2">Price / Night</label>
                        <div class="relative">
                            <span class="absolute left-4 top-3.5 text-slate-500 font-bold">$</span>
                            <input class="w-full bg-slate-950 border border-slate-800 rounded-xl pl-8 pr-4 py-3.5 focus:outline-none focus:border-[#ff385c] focus:ring-1 focus:ring-[#ff385c] text-white transition-all placeholder:text-slate-600 shadow-inner" required type="text" name='price' value="<%=home.price %>">  
                        </div>
                    </div>
                    <div class="w-1/2">
                        <label class="block text-xs font-bold text-slate-400 uppercase tracking-wider mb-2">Location</label>
                        <input class="w-full bg-slate-950 border border-slate-800 rounded-xl px-4 py-3.5 focus:outline-none focus:border-[#ff385c] focus:ring-1 focus:ring-[#ff385c] text-white transition-all placeholder:text-slate-600 shadow-inner" required type="text" name='location' value="<%=home.location %>">
                    </div>
                </div>

                <div>
                    <label class="block text-xs font-bold text-slate-400 uppercase tracking-wider mb-2">Description</label>
                    <textarea class="w-full bg-slate-950 border border-slate-800 rounded-xl px-4 py-3.5 focus:outline-none focus:border-[#ff385c] focus:ring-1 focus:ring-[#ff385c] text-white transition-all placeholder:text-slate-600 shadow-inner resize-y" required name='description' rows="3" placeholder="Tell guests what makes your place special..."><%=home.description %></textarea>
                </div>

                <div>
                    <label class="block text-xs font-bold text-slate-400 uppercase tracking-wider mb-2">Photo URL</label>
                    <input class="w-full bg-slate-950 border border-slate-800 rounded-xl px-4 py-3.5 focus:outline-none focus:border-[#ff385c] focus:ring-1 focus:ring-[#ff385c] text-white transition-all placeholder:text-slate-600 shadow-inner" required type="text" name='photo' value="<%=home.photo %>">
                </div>
                
                <button type='submit' class="w-full bg-[#ff385c] hover:bg-[#e03150] text-white py-4 rounded-xl font-bold mt-8 transition-all duration-300 transform active:scale-[0.98] shadow-lg shadow-[#ff385c]/20 uppercase tracking-wider text-sm flex justify-center items-center gap-2 cursor-pointer hover:gap-5">
                    Save Changes
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                </button>
            </form>
        </div>

    </main>
</body>
</html>