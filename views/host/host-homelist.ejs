<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Airbnb Admin | Manage List</title>
    <link rel="stylesheet" href="/output.css">
</head>

<body class="bg-slate-950 text-slate-200 min-h-screen font-sans flex flex-col selection:bg-[#ff385c]/30">

    <header
        class="sticky top-0 z-50 w-full flex flex-col md:flex-row justify-between items-center px-6 py-4 md:px-12 bg-slate-950/80 backdrop-blur-xl border-b border-slate-800/60 shadow-sm shadow-slate-900/20">
        <div class="flex items-center gap-3 mb-4 md:mb-0">
            <a href="/"
                class="flex items-center gap-2 text-[#ff385c] font-bold text-2xl tracking-tight transition-transform duration-300">
                <svg class="w-8 h-8 fill-current" viewBox="0 0 32 32" xmlns="http://www.w3.org/2000/svg">
                    <path
                        d="M16 1.4c-8.1 0-14.6 6.5-14.6 14.6 0 8.1 6.5 14.6 14.6 14.6 8.1 0 14.6-6.5 14.6-14.6 0-8.1-6.5-14.6-14.6-14.6zm0 27.2c-7 0-12.6-5.6-12.6-12.6 0-7 5.6-12.6 12.6-12.6 7 0 12.6 5.6 12.6 12.6 0 7-5.6 12.6-12.6 12.6zm3.6-17.1c-1-1.1-2.2-1.7-3.6-1.7-1.4 0-2.6.6-3.6 1.7-1.1 1.2-1.8 3-1.8 5.2s.7 4 1.8 5.2c1 1.1 2.2 1.7 3.6 1.7 1.4 0 2.6-.6 3.6-1.7 1.1-1.2 1.8-3 1.8-5.2s-.7-4-1.8-5.2zm-1.5 8.9c-.6.6-1.3.9-2.1.9-.8 0-1.5-.3-2.1-.9-.6-.7-.9-1.9-.9-3.7 0-1.8.3-3 .9-3.7.6-.6 1.3-.9 2.1-.9.8 0 1.5.3 2.1.9.6.7.9 1.9.9 3.7 0 1.8-.3 3-.9 3.7z" />
                </svg>
                Airbnb
            </a>
            <span
                class="bg-[#ff385c]/10 text-[#ff385c] border border-[#ff385c]/20 text-[10px] font-bold uppercase tracking-wider py-1 px-2.5 rounded-md shadow-sm">
                Admin
            </span>
        </div>

        <%-include('../partials/hostNavPartial')%>
    </header>

    <main class="flex-grow max-w-6xl mx-auto w-full p-6 lg:p-12 relative">
        <div
            class="mb-12 flex flex-col md:flex-row justify-between items-start md:items-end gap-6 border-b border-slate-800/60 pb-8">
            <div>
                <h1 class="text-4xl font-extrabold text-white tracking-tight mb-3">Inventory Management</h1>
                <p class="text-slate-400 text-lg">View, edit, and manage all your active property listings.</p>
            </div>
            <a href="/host/add-home"
                class="inline-flex items-center gap-2 px-6 py-3.5 bg-[#ff385c] text-white rounded-xl font-bold text-sm hover:bg-[#e03150] transition-all duration-300 shadow-lg shadow-[#ff385c]/20 transform active:scale-95 shrink-0">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
                </svg>
                Add New Listing
            </a>
        </div>

        <% if (homelist && homelist.length> 0) { %>
            <div class="flex flex-col gap-8">
                <% homelist.forEach(home=> { %>
                    <div
                        class="group bg-slate-900/40 backdrop-blur-sm border border-slate-800/60 rounded-[2rem] overflow-hidden transition-colors duration-300 flex flex-col lg:flex-row">

                        <div class="relative w-full lg:w-80 shrink-0 overflow-hidden h-64 lg:h-auto">
                            <img src="<%=home.photo%>" alt="<%=home.name%>"
                                class="w-full h-full object-cover opacity-85 group-hover:opacity-100 transition-opacity duration-300 ease-out">

                            <div
                                class="absolute inset-0 bg-gradient-to-t from-slate-950 via-transparent to-transparent lg:bg-gradient-to-r lg:from-transparent lg:to-slate-900/70 opacity-90 transition-opacity duration-300">
                            </div>

                            <div class="absolute top-4 left-4 flex flex-col gap-2 z-10">
                                <span
                                    class="bg-emerald-500/20 text-emerald-400 text-[10px] font-bold px-3 py-1 rounded-full uppercase tracking-widest border border-emerald-500/30 w-fit backdrop-blur-md">
                                    ● Active
                                </span>
                            </div>
                        </div>

                        <div class="p-6 lg:p-8 flex flex-col flex-grow justify-between">

                            <div>
                                <div
                                    class="flex flex-col md:flex-row justify-between items-start md:items-center mb-2 gap-4">
                                    <h3 class="text-2xl font-extrabold text-white tracking-tight line-clamp-1">
                                        <%=home.name%>
                                    </h3>
                                    <div
                                        class="flex items-end gap-1 shrink-0 bg-slate-950/50 px-4 py-2 rounded-xl border border-slate-800 transition-colors duration-300 group-hover:border-slate-700">
                                        <span class="text-white font-black text-xl tracking-tight">$<%=home.price%>
                                        </span>
                                        <span
                                            class="text-slate-500 text-xs font-semibold uppercase tracking-wider mb-1">/
                                            night</span>
                                    </div>
                                </div>

                                <div class="flex items-center justify-between text-slate-400 text-sm font-medium mb-5">
                                    <div class="flex items-center">
                                        <svg class="w-4 h-4 mr-1.5 text-[#ff385c]" fill="none" stroke="currentColor"
                                            viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                                d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z">
                                            </path>
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                                d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
                                        </svg>
                                        <%=home.location%>
                                    </div>
                                    <span class="text-[10px] uppercase tracking-widest font-bold text-slate-500">ID:
                                        <%=home._id%>
                                    </span>
                                </div>

                                <div
                                    class="bg-slate-950/30 rounded-xl p-4 border border-slate-800/50 transition-colors duration-300 group-hover:bg-slate-950/50 group-hover:border-slate-700/50">
                                    <h4 class="text-[10px] font-bold text-slate-500 uppercase tracking-wider">
                                        Description</h4>
                                    <p class="text-slate-300 text-sm leading-relaxed line-clamp-3 whitespace-pre-line">
                                        <%=home.description%>
                                    </p>
                                </div>
                                <div class="mt-1 p-1 ">
                                    <a href="/host/add-rules/<%=home._id%>" class="text-sm text-blue-400 hover:text-blue-500 cursor-pointer transition-all duration-200">
                                        Add Rules and Guide as PDF
                                    </a>
                                </div>
                            </div>

                            <div class="flex flex-col sm:flex-row gap-3 mt-8 pt-6 border-t border-slate-800/60">
                                <a href="/host/edit-homes/<%=home._id%>"
                                    class="flex-1 flex justify-center items-center py-3 px-4 bg-slate-800 text-slate-200 hover:text-white hover:bg-slate-700 rounded-xl font-semibold text-sm tracking-wide transition-all duration-200 border border-slate-700 hover:border-slate-600 hover:shadow-md active:scale-[0.98]">
                                    <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                            d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z">
                                        </path>
                                    </svg>
                                    Edit Details
                                </a>

                                <form action="/host/delete-home/<%=home._id%>" method="POST" class="flex-1 m-0">
                                    <button type="submit"
                                        class="w-full flex justify-center items-center py-3 px-4 bg-transparent text-slate-400 hover:text-rose-500 hover:bg-rose-500/10 rounded-xl font-semibold text-sm tracking-wide transition-all duration-200 border border-slate-800 hover:border-rose-500/30 active:scale-[0.98]">
                                        <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                                d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16">
                                            </path>
                                        </svg>
                                        Remove Listing
                                    </button>
                                </form>
                            </div>

                        </div>
                    </div>
                    <% }) %>
            </div>
            <% } else { %>
                <div
                    class="border-2 border-dashed border-slate-800 rounded-[2rem] flex flex-col items-center justify-center p-16 text-center bg-slate-900/20 min-h-[400px]">
                    <div
                        class="w-20 h-20 rounded-full bg-slate-900 border border-slate-800 flex items-center justify-center mb-6 text-slate-600 shadow-inner">
                        <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                                d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10">
                            </path>
                        </svg>
                    </div>
                    <h3 class="text-2xl font-bold text-white mb-2 tracking-tight">No listings yet</h3>
                    <p class="text-slate-500 font-medium tracking-wide max-w-sm mx-auto">Your inventory loop will
                        populate here. Add homes to see them in this list.</p>
                    <a href="/host/add-home"
                        class="mt-8 px-6 py-3 bg-slate-800 text-white rounded-xl font-bold text-sm hover:bg-slate-700 transition-all border border-slate-700">Get
                        Started</a>
                </div>
                <% } %>
    </main>
</body>

</html>