<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Airbnb Admin | Manage List</title>
    <link rel="stylesheet" href="/output.css">
</head>
<body class="bg-slate-950 text-slate-200 min-h-screen font-sans flex flex-col selection:bg-[#ff385c]/30">
    
    <header class="sticky top-0 z-50 w-full flex flex-col md:flex-row justify-between items-center px-6 py-4 md:px-12 bg-slate-950/80 backdrop-blur-xl border-b border-slate-800/60 shadow-sm shadow-slate-900/20">
        <div class="flex items-center gap-3 mb-4 md:mb-0">
            <a href="/host/" class="flex items-center gap-2 text-[#ff385c] font-bold text-2xl tracking-tight hover:scale-105 transition-transform duration-300">
                <svg class="w-8 h-8 fill-current" viewBox="0 0 32 32" xmlns="http://www.w3.org/2000/svg">
                    <path d="M16 1.4c-8.1 0-14.6 6.5-14.6 14.6 0 8.1 6.5 14.6 14.6 14.6 8.1 0 14.6-6.5 14.6-14.6 0-8.1-6.5-14.6-14.6-14.6zm0 27.2c-7 0-12.6-5.6-12.6-12.6 0-7 5.6-12.6 12.6-12.6 7 0 12.6 5.6 12.6 12.6 0 7-5.6 12.6-12.6 12.6zm3.6-17.1c-1-1.1-2.2-1.7-3.6-1.7-1.4 0-2.6.6-3.6 1.7-1.1 1.2-1.8 3-1.8 5.2s.7 4 1.8 5.2c1 1.1 2.2 1.7 3.6 1.7 1.4 0 2.6-.6 3.6-1.7 1.1-1.2 1.8-3 1.8-5.2s-.7-4-1.8-5.2zm-1.5 8.9c-.6.6-1.3.9-2.1.9-.8 0-1.5-.3-2.1-.9-.6-.7-.9-1.9-.9-3.7 0-1.8.3-3 .9-3.7.6-.6 1.3-.9 2.1-.9.8 0 1.5.3 2.1.9.6.7.9 1.9.9 3.7 0 1.8-.3 3-.9 3.7z"/>
                </svg>
                Airbnb
            </a>
            <span class="bg-[#ff385c]/10 text-[#ff385c] border border-[#ff385c]/20 text-[10px] font-bold uppercase tracking-wider py-1 px-2.5 rounded-md shadow-sm">
                Admin
            </span>
        </div>

        <nav>
            <ul class="flex flex-wrap justify-center items-center gap-6 md:gap-10 text-sm font-semibold tracking-wide">
                <li><a href="/host/host-homelist" class="active text-[#ff385c] border-b-2 border-[#ff385c] pb-1 transition-all duration-300">Home-list</a></li>
                <li><a href="/host/" class="text-slate-400 border-b-2 border-transparent hover:text-white hover:border-slate-600 pb-1 transition-all duration-300">Home</a></li>
                <li><a href="/host/edit-homes" class="text-slate-400 border-b-2 border-transparent hover:text-white hover:border-slate-600 pb-1 transition-all duration-300">Edit-homes</a></li>
                <li><a href="/" class="text-green-400 border-b-2 border-transparent hover:text-white hover:border-slate-600 pb-1 transition-all duration-300">Logout</a></li>
            </ul>
        </nav>
    </header>

    <main class="flex-grow max-w-7xl mx-auto w-full p-8 lg:p-12 relative">
        <div class="mb-10 flex justify-between items-end">
            <div>
                <h1 class="text-3xl font-extrabold text-white tracking-tight mb-2">Inventory Management</h1>
                <p class="text-slate-400">View and manage all active listings on the platform.</p>
            </div>
            <a href="/host/add-home" class="hidden md:inline-flex items-center gap-2 px-6 py-2.5 bg-white text-slate-950 rounded-xl font-bold text-sm hover:bg-[#ff385c] hover:text-white transition-all duration-300 shadow-lg">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
                Add Listing
            </a>
        </div>

        <div class="border-2 border-dashed border-slate-800 rounded-[2rem] flex flex-col items-center justify-center p-16 text-center bg-slate-900/20 min-h-[400px]">
            <div class="w-16 h-16 rounded-full bg-slate-900 border border-slate-800 flex items-center justify-center mb-6 text-slate-600">
                <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path></svg>
            </div>
            <p class="text-slate-500 font-medium tracking-wide text-lg">Your inventory loop will populate here.<br><span class="text-sm font-normal">Add homes to see them in this grid.</span></p>
        </div>
    </main>
</body>
</html>