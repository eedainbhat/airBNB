    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Airbnb Admin | Home</title>
    <link rel="stylesheet" href="/output.css">
</head>
<body class="bg-slate-950 text-slate-200 min-h-screen font-sans flex flex-col selection:bg-[#ff385c]/30">
    
    <header class="sticky top-0 z-50 w-full flex flex-col md:flex-row justify-between items-center px-6 py-4 md:px-12 bg-slate-950/80 backdrop-blur-xl border-b border-slate-800/60 shadow-sm shadow-slate-900/20">
        <div class="flex items-center gap-3 mb-4 md:mb-0">
            <a href="/host/" class="flex items-center gap-2 text-[#ff385c] font-bold text-2xl tracking-tight hover:scale-105 transition-transform duration-300">
                <svg class="w-8 h-8 fill-current" viewBox="0 0 32 32" xmlns="http://www.w3.org/2000/svg">
                    <path d="M16 1.4c-8.1 0-14.6 6.5-14.6 14.6 0 8.1 6.5 14.6 14.6 14.6 8.1 0 14.6-6.5 14.6-14.6 0-8.1-6.5-14.6-14.6-14.6zm0 27.2c-7 0-12.6-5.6-12.6-12.6 0-7 5.6-12.6 12.6-12.6 7 0 12.6 5.6 12.6 12.6 0 7-5.6 12.6-12.6 12.6zm3.6-17.1c-1-1.1-2.2-1.7-3.6-1.7-1.4 0-2.6.6-3.6 1.7-1.1 1.2-1.8 3-1.8 5.2s.7 4 1.8 5.2c1 1.1 2.2 1.7 3.6 1.7 1.4 0 2.6-.6 3.6-1.7 1.1-1.2 1.8-3 1.8-5.2s-.7-4-1.8-5.2zm-1.5 8.9c-.6.6-1.3.9-2.1.9-.8 0-1.5-.3-2.1-.9-.6-.7-.9-1.9-.9-3.7 0-1.8.3-3 .9-3.7.6-.6 1.3-.9 2.1-.9.8 0 1.5.3 2.1.9.6.7.9 1.9.9 3.7 0 1.8-.3 3-.9 3.7z"/>
                </svg>
                Airbnb
            </a>
            <span class="bg-[#ff385c]/10 text-[#ff385c] border border-[#ff385c]/20 text-[10px] font-bold uppercase tracking-wider py-1 px-2.5 rounded-md shadow-sm">
                Admin
            </span>
        </div>

        <nav>
            <ul class="flex flex-wrap justify-center items-center gap-6 md:gap-10 text-sm font-semibold tracking-wide">
                <li><a href="/host/host-homelist" class="text-slate-400 border-b-2 border-transparent hover:text-white hover:border-slate-600 pb-1 transition-all duration-300">Home-list</a></li>
                <li><a href="/host/" class="active text-[#ff385c] border-b-2 border-[#ff385c] pb-1 transition-all duration-300">Home</a></li>
                <li><a href="/host/edit-homes" class="text-slate-400 border-b-2 border-transparent hover:text-white hover:border-slate-600 pb-1 transition-all duration-300">Edit-homes</a></li>
                <li><a href="/" class="text-green-400 border-b-2 border-transparent hover:text-white hover:border-slate-600 pb-1 transition-all duration-300">Logout</a></li>
            </ul>
        </nav>
    </header>

    <main class="flex-grow flex flex-col items-center justify-center relative px-4 py-20 overflow-hidden">
        <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[500px] h-[500px] bg-[#ff385c]/10 blur-[100px] rounded-full pointer-events-none"></div>

        <div class="max-w-2xl text-center relative z-10">
            <div class="w-20 h-20 bg-slate-900 border border-slate-800 rounded-full flex items-center justify-center mx-auto mb-8 text-[#ff385c] shadow-inner hover:rotate-[40deg] transition-transform duration-300">
                <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
            </div>
            <h1 class="text-4xl md:text-5xl font-black text-white mb-6 tracking-tight drop-shadow-lg">Host Dashboard</h1>
            <p class="text-slate-400 text-lg mb-10 max-w-md mx-auto leading-relaxed">Manage your listings, update property details, and oversee your inventory from this secure command center.</p>
            <a href="/host/add-home" class="inline-flex items-center gap-2 px-8 py-4 bg-[#ff385c] text-white rounded-full font-bold text-lg hover:bg-[#e03150] transition-all duration-300 transform hover:translate-y-[-3px] shadow-[0_0_30px_-5px_rgba(255,56,92,0.4)]">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
                Add New Home
            </a>
        </div>
    </main>
</body>
</html>