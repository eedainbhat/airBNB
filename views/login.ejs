<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Airbnb | Login</title>
    <link rel="stylesheet" href="/output.css">
</head>

<body
    class="bg-[#020617] text-slate-200 min-h-screen flex flex-col items-center justify-center font-sans overflow-hidden relative selection:bg-[#ff385c]/30">

    <div
        class="absolute top-0 left-1/4 w-[500px] h-[500px] bg-[#ff385c]/20 rounded-full mix-blend-screen filter blur-[128px] animate-[pulse_6s_ease-in-out_infinite] pointer-events-none">
    </div>
    <div
        class="absolute bottom-0 right-1/4 w-[500px] h-[500px] bg-emerald-500/15 rounded-full mix-blend-screen filter blur-[128px] animate-[pulse_8s_ease-in-out_infinite_reverse] pointer-events-none">
    </div>

    <div class="relative z-10 w-full max-w-md px-6 perspective-1000">

        <div
            class="flex flex-col bg-slate-900/60 backdrop-blur-2xl border border-slate-700/50 p-8 sm:p-10 rounded-[2.5rem] shadow-[0_20px_80px_-15px_rgba(0,0,0,0.5)]">

            <div class="flex flex-col items-center mb-8">

                <h1 class="text-3xl font-black text-white tracking-tight mb-2">Login</h1>
                <p class="text-slate-400 font-medium text-sm">Please enter your details to sign in.</p>
            </div>

            <form action="/login" method="POST" class="flex flex-col gap-5">

                <div class="flex flex-col gap-2">
                    <label for="identifier" class="text-xs font-bold text-slate-400 uppercase tracking-wider ml-1">Email
                        or Username</label>
                    <div class="relative">
                        <div
                            class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none text-slate-500">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                    d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
                            </svg>
                        </div>
                        <input type="text" id="identifier" name="identifier" required
                            placeholder="Enter your email or name"
                            class="w-full pl-11 pr-4 py-3.5 bg-slate-950/50 border border-slate-800 rounded-xl text-slate-200 placeholder-slate-600 focus:outline-none focus:border-[#ff385c]/50 focus:ring-1 focus:ring-[#ff385c]/50 transition-all duration-300">
                    </div>
                </div>

                <div class="flex flex-col gap-2">
                    <div class="flex justify-between items-center ml-1">
                        <label for="password"
                            class="text-xs font-bold text-slate-400 uppercase tracking-wider">Password</label>
                            <a href="/forgot-password" class="text-xs font-semibold text-[#ff385c] hover:text-[#e03150] transition-colors">Forgot?</a>
                    </div>
                    <div class="relative">
                        <div
                            class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none text-slate-500">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                    d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z">
                                </path>
                            </svg>
                        </div>

                        <input type="password" id="password" name="password" required placeholder="••••••••"
                            class="w-full pl-11 pr-12 py-3.5 bg-slate-950/50 border border-slate-800 rounded-xl text-slate-200 placeholder-slate-600 focus:outline-none focus:border-[#ff385c]/50 focus:ring-1 focus:ring-[#ff385c]/50 transition-all duration-300">

                        <button type="button" id="togglePassword"
                            class="absolute inset-y-0 right-0 pr-4 flex items-center text-slate-500 hover:text-[#ff385c] transition-colors focus:outline-none">

                            <svg id="eyeIcon" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                    d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                    d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                            </svg>

                            <svg id="eyeSlashIcon" class="w-5 h-5 hidden" fill="none" stroke="currentColor"
                                viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                    d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l3.59 3.59m0 0A9.953 9.953 0 0112 5c4.478 0 8.268 2.943 9.543 7a10.025 10.025 0 01-4.132 5.411m0 0L21 21" />
                            </svg>

                        </button>
                    </div>
                </div>

                <button type="submit"
                    class="mt-2 w-full flex justify-center items-center py-3.5 px-4 bg-[#ff385c] text-white rounded-xl font-bold tracking-wide hover:bg-[#e03150] hover:shadow-[0_0_20px_rgba(255,56,92,0.3)] transition-all duration-300 active:scale-[0.98]">
                    Sign In
                </button>
            </form>

            <div class="flex items-center my-6 gap-4">
                <div class="flex-grow border-t border-slate-800/80"></div>
                <span class="text-xs font-bold text-slate-500 uppercase tracking-wider">Or continue with</span>
                <div class="flex-grow border-t border-slate-800/80"></div>
            </div>

            <button type="button"
                class="w-full flex justify-center items-center gap-3 py-3.5 px-4 bg-slate-950 text-slate-300 hover:text-white rounded-xl font-semibold tracking-wide border border-slate-800 hover:border-slate-600 hover:bg-slate-900 transition-all duration-300 active:scale-[0.98]">
                <svg class="w-5 h-5" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                    <path
                        d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"
                        fill="#4285F4" />
                    <path
                        d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"
                        fill="#34A853" />
                    <path
                        d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"
                        fill="#FBBC05" />
                    <path
                        d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"
                        fill="#EA4335" />
                </svg>
                Google
            </button>

            <p class="text-center mt-8 text-sm text-slate-400 font-medium">
                Don't have an account? 
                <a href="/signup" class="text-[#ff385c] hover:text-white font-bold transition-colors ml-1">Sign up</a>
            </p>

        </div>
    </div>
    <script>
        const togglePassword = document.getElementById('togglePassword');
        const password = document.getElementById('password');
        const eyeIcon = document.getElementById('eyeIcon');
        const eyeSlashIcon = document.getElementById('eyeSlashIcon');

        togglePassword.addEventListener('click', function () {
            const type = password.getAttribute('type') === 'password' ? 'text' : 'password';
            password.setAttribute('type', type);

            eyeIcon.classList.toggle('hidden');
            eyeSlashIcon.classList.toggle('hidden');
        });
    </script>
</body>

</html>