<% if (typeof errorMessages !=='undefined' && errorMessages && errorMessages.length> 0) { %>
    <div class="flex items-start gap-3 p-4 mb-6 bg-red-50 border border-red-200 rounded-xl shadow-sm animate-[pulse_0.5s_ease-in-out]"
        role="alert">

        <svg class="w-5 h-5 text-red-500 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z">
            </path>
        </svg>

        <div class="flex flex-col">
            <h3 class="text-sm font-bold text-red-800 tracking-tight">Something went wrong</h3>
            <% errorMessages.forEach((error)=> { %>
                <p class="text-xs text-red-600 mt-1 leading-relaxed font-medium">
                    <%= error %>
                </p>
                <% }) %>
        </div>

        <button type="button" onclick="this.parentElement.style.display='none'"
            class="ml-auto text-red-400 hover:text-red-600 hover:bg-red-100 p-1 rounded-md transition-colors focus:outline-none focus:ring-2 focus:ring-red-500/50">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
            </svg>
        </button>

    </div>
    <% } %>